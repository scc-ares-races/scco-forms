addon    SCCoPIFO
html     form-road-closure.html
version  1.1
title    Road Closure Form
indef    a road closure form
create   RoadCl rc
pdfFile  Road_Closure_v20260307.pdf
deftext  FT Times-Roman FS 12.0 MS 8.0 LH 1.15 A lF WR f CL t C 000099

field MsgNo originMessageID
  label    "1. Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 233.56 R 326.32 B 713.00 T 730.96 BL 718.32

field DestMsgNo destinationMessageID
  label    "2. Destination Message Number"
  type     messageID
  pdf      text L 437.20 R 564.76 B 713.00 T 730.96 BL 718.32

field 1a. messageDate
  label    "3. Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  81.04 R 132.76 B 658.88 T 678.76 BL 665.04

field 1b. messageTime
  label    "4. Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 181.12 R 236.32 B 658.88 T 678.76 BL 665.04

field -
  label    "3-4. Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    "5. Handling"
  type     restricted
  value    ROUTINE
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 309.84 Y 669.12 R 2.72
  pdf      if 5.=PRIORITY then circle X 487.92 Y 669.12 R 2.72
  pdf      if 5.=ROUTINE then circle X 406.80 Y 669.06 R 2.84

field 7a. toICSPosition
  label    "6. To ICS Position"
  value    "Public Works Group"
  choice   Public Works Group
  choice   Construction &amp; Eng. Branch
  choice   Operations
  presence required
  width    30
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 142.12 R 299.32 B 640.88 T 653.92 BL 643.68

field 7b. toLocation
  label    "7. To Location"
  value    "County EOC"
  presence required
  width    32
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 142.12 R 299.32 B 622.88 T 635.92 BL 625.68

field 7c. toName
  label    "8. To Name"
  width    34
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 142.12 R 299.32 B 604.88 T 617.92 BL 607.68

field 7d. toContact
  label    "9. To Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 142.12 R 299.32 B 582.68 T 599.92 BL 587.64

field 8a. fromICSPosition
  label    "10. From ICS Position"
  presence required
  width    30
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 403.96 R 563.44 B 640.88 T 653.92 BL 643.68

field 8b. fromLocation
  label    "11. From Location"
  presence required
  width    32
  help     "This is the location of the message author.  It is required."
  pdf      text L 403.96 R 563.44 B 622.88 T 635.92 BL 625.68

field 8c. fromName
  label    "12. From Name"
  width    34
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 403.96 R 563.44 B 604.88 T 617.92 BL 607.68

field 8d. fromContact
  label    "13. From Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 403.96 R 563.44 B 582.68 T 599.92 BL 587.64

field 20.
  label    "21. Jurisdiction"
  choice   Campbell
  choice   Cupertino
  choice   Gilroy
  choice   Los Altos
  choice   Los Altos Hills
  choice   Los Gatos
  choice   Milpitas
  choice   Monte Sereno
  choice   Morgan Hill
  choice   Mountain View
  choice   Palo Alto
  choice   San Jose
  choice   Santa Clara (City)
  choice   Saratoga
  choice   Sunnyvale
  choice   Santa Clara County
  choice   County unincorporated
  presence required
  help     "This is the name of the jurisdiction originating the road closure.  It is required."
  pdf      text L 147.52 R 563.44 B 545.96 T 559.60 BL 549.12

field 21. messageSummary
  label    "22. Road/Intersection"
  presence required
  width    89
  help     "This is the road or intersection with the closure.  It should be unique among all road closure reports from this jurisdiction.  It is required."
  pdf      text L 147.52 R 563.44 B 523.52 T 541.12 BL 528.60

field 22.
  label    "23. Location"
  type     multiline
  presence required
  width    108
  help     "This is the detailed location of the closure.  It is required."
  pdf      text L  41.44 R 563.44 B 442.52 T 506.68 A lt

field 23. defaultBody
  label    "24. Details"
  type     multiline
  presence required
  width    108
  help     "This field has details of the closure.  It is required."
  pdf      text L  41.44 R 563.44 B 361.40 T 425.68 A lt

field 24.
  label    "25. Status"
  type     restricted
  mchoice  "Planned Closure" a. Planned Closure
  mchoice  Closed b. Closed
  mchoice  Reopened c. Reopened
  presence required
  help     "This identifies the status of the closure.  It is required."
  pdf      if 24.="Planned Closure" then circle X 155.64 Y 350.52 R 2.96
  pdf      if 24.=Closed then circle X 299.64 Y 350.52 R 2.84
  pdf      if 24.=Reopened then circle X 407.64 Y 350.52 R 2.84

field 30d.
  label    "31. Closure Start Date"
  type     date
  help     "This is the date when the closure started or will start."
  pdf      text L 147.64 R 299.92 B 298.40 T 311.44 BL 301.20

field 30t.
  label    "32. Closure Start Time"
  type     time
  help     "This is the time of day when the closure started or will start."
  pdf      text L 414.76 R 563.44 B 298.40 T 311.44 BL 301.20

field -
  label    "31-32. Closure Start"
  type     dateTime
  children 30d. 30t.
  help     "This is the date and time when the closure started or will start, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 31d.
  label    "33. Closure End Date"
  type     date
  help     "This is the date when the closure ended or will end."
  pdf      text L 147.64 R 299.92 B 277.16 T 293.92 BL 281.88

field 31t.
  label    "34. Closure End Time"
  type     time
  help     "This is the time of day when the closure ended or will end."
  pdf      text L 414.76 R 563.44 B 277.16 T 293.92 BL 281.88

field -
  label    "33-34. Closure End"
  type     dateTime
  children 31d. 31t.
  help     "This is the date and time when the closure ended or will end, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field OpRelayRcvd
  label    "Operator: Relay Received"
  width    36
  help     "This is the name of the station from which this message was directly received.  It is filled in for messages that go through a relay station."
  pdf      text L 108.88 R 319.48 B 230.84 T 245.32 BL 234.36

field OpRelaySent
  label    "Operator: Relay Sent"
  width    36
  help     "This is the name of the station to which this message was directly sent.  It is filled in for messages that go through a relay station."
  pdf      text L 353.92 R 564.76 B 230.84 T 245.32 BL 234.36

field OpName operatorName
  label    "Operator: Name"
  presence required
  pdf      text L  74.92 R 247.72 B 211.88 T 226.36 BL 215.40

field OpCall operatorCall
  label    "Operator: Call Sign"
  presence required
  pdf      text L 300.16 R 364.24 B 211.88 T 226.36 BL 215.40

field -
  label    Operator
  type     join
  children OpName OpCall

field OpDate operatorDate
  label    "Operator: Date"
  type     date
  pdf      text L 399.88 R 471.88 B 211.88 T 226.36 BL 215.40

field OpTime operatorTime
  label    "Operator: Time"
  type     time
  pdf      text L 535.84 R 564.76 B 211.88 T 226.36 BL 215.40

field -
  label    "Operator: Date/Time"
  type     dateTime
  children OpDate OpTime

field -
  pdf      box L 281.04 R 332.28 B  35.28 T  46.68 F FFFFFF
