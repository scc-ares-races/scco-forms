addon    SCCoPIFO
html     form-cpod-site-info.html
version  1.1
title    CPOD Site Information Form
indef    a CPOD site information form
create   CPODSite cs
pdfFile  CPOD_Site_Information_v20260307.pdf
deftext  FT Times-Roman FS 12.0 MS 8.0 LH 1.15 A lF WR f CL t C 000099

field MsgNo originMessageID
  label    "1. Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 229.00 R 324.76 B 713.00 T 730.96 BL 718.32
  pdf      text P 2 L 446.48 R 565.20 B 711.60 T 752.88 BL 723.11

field DestMsgNo destinationMessageID
  label    "2. Destination Message Number"
  type     messageID
  pdf      text L 432.52 R 564.76 B 713.00 T 730.96 BL 718.32

field 1a. messageDate
  label    "3. Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  79.04 R 132.76 B 658.88 T 678.76 BL 665.04

field 1b. messageTime
  label    "4. Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 181.12 R 236.32 B 658.88 T 678.76 BL 665.04

field -
  label    "3-4. Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    "5. Handling"
  type     restricted
  value    ROUTINE
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 309.84 Y 669.06 R 2.84
  pdf      if 5.=PRIORITY then circle X 406.80 Y 669.06 R 2.84
  pdf      if 5.=ROUTINE then circle X 487.92 Y 669.06 R 2.84

field 7a. toICSPosition
  label    "6. To ICS Position"
  value    "CPOD Unit"
  choice   CPOD Unit
  choice   Mass Care & Emerg. Asst. Branch
  choice   Operations
  presence required
  width    30
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 142.12 R 299.32 B 640.88 T 653.92 BL 643.68

field 7b. toLocation
  label    "7. To Location"
  value    "County EOC"
  presence required
  width    32
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 142.12 R 299.32 B 622.88 T 635.92 BL 625.68

field 7c. toName
  label    "8. To Name"
  width    34
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 142.12 R 299.32 B 604.88 T 617.92 BL 607.68

field 7d. toContact
  label    "9. To Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 142.12 R 299.32 B 582.68 T 599.92 BL 587.64

field 8a. fromICSPosition
  label    "10. From ICS Position"
  presence required
  width    30
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 403.96 R 563.44 B 640.88 T 653.92 BL 643.68

field 8b. fromLocation
  label    "11. From Location"
  presence required
  width    32
  help     "This is the location of the message author.  It is required."
  pdf      text L 403.96 R 563.44 B 622.88 T 635.92 BL 625.68

field 8c. fromName
  label    "12. From Name"
  width    34
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 403.96 R 563.44 B 604.88 T 617.92 BL 607.68

field 8d. fromContact
  label    "13. From Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 403.96 R 563.44 B 582.68 T 599.92 BL 587.64

field 20.
  label    "21. Jurisdiction"
  choice   Campbell
  choice   Cupertino
  choice   Gilroy
  choice   Los Altos
  choice   Los Altos Hills
  choice   Los Gatos
  choice   Milpitas
  choice   Monte Sereno
  choice   Morgan Hill
  choice   Mountain View
  choice   Palo Alto
  choice   San Jose
  choice   Santa Clara (City)
  choice   Saratoga
  choice   Sunnyvale
  choice   Santa Clara County
  choice   County unincorporated
  presence required
  help     "This is the name of the jurisdiction responsible for the CPOD.  It is required."
  pdf      text L 131.20 R 563.44 B 546.20 T 559.84 BL 549.24

field 21d. formDate
  label    "22. Prepared Date"
  type     date
  presence required
  help     "This is the date when the form was prepared.  It is required."
  pdf      text L 131.20 R 303.76 B 527.72 T 541.24 BL 530.76

field 21t.
  label    "23. Prepared Time"
  type     time
  presence required
  help     "This is the time when the form was prepared.  It is required."
  pdf      text L 402.16 R 563.44 B 527.72 T 541.24 BL 530.76

field -
  label    "22-23. Prepared Date/Time"
  type     dateTime
  children 21d. 21t.
  presence required
  help     "This is the date and time when the form was prepared, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 22. messageSummary
  label    "31. Site Name"
  presence required
  width    80
  help     "This is the name of the CPOD site.  It is required."
  pdf      text L 111.52 R 563.44 B 491.60 T 505.24 BL 494.76

field 23.
  label    "32. CPOD Type"
  type     restricted
  mchoice  "Type I" a. Type I
  mchoice  "Type II" b. Type II
  mchoice  "Type III" c. Type III
  mchoice  LSA d. LSA
  mchoice  "Non-CPOD Distribution Point" e. Non-CPOD Distribution Point
  presence required
  help     "This is the type of CPOD.  It is required."
  pdf      if 23.="Type I" then circle X 119.82 Y 481.20 R 2.90
  pdf      if 23.="Type III" then circle X 227.64 Y 481.20 R 2.72
  pdf      if 23.="Non-CPOD Distribution Point" then circle X 396.54 Y 481.20 R 2.90
  pdf      if 23.="Type II" then circle X 119.64 Y 465.66 R 2.84
  pdf      if 23.=LSA then circle X 227.70 Y 465.72 R 2.90

field 24.
  label    "33. Status"
  type     restricted
  mchoice  Activated a. Activated
  mchoice  "Pending Activation" b. Pending Activation
  mchoice  "Pending Demobilization" c. Pending Demobilization
  mchoice  Demobilization d. Demobilization
  mchoice  "Not Activated" e. Not Activated
  presence required
  help     "This is the status of the CPOD.  It is required."
  pdf      if 24.=Activated then circle X 263.64 Y 449.10 R 2.84
  pdf      if 24.="Pending Demobilization" then circle X 407.64 Y 449.10 R 2.84
  pdf      if 24.="Not Activated" then circle X 119.64 Y 449.10 R 2.84
  pdf      if 24.="Pending Activation" then circle X 263.64 Y 433.56 R 2.72
  pdf      if 24.=Demobilization then circle X 119.70 Y 433.56 R 2.90

field 25a.
  label    "34. Address"
  presence required
  width    35
  help     "This is the street address of the CPOD site.  It is required."
  pdf      text L 101.20 R 263.32 B 409.16 T 422.56 BL 412.20

field 25c.
  label    "35. City"
  presence required
  width    31
  help     "This is the city portion of the address of the CPOD site.  It is required."
  pdf      text L 311.44 R 447.76 B 409.16 T 422.56 BL 412.20

field 25z.
  label    "36. ZIP Code"
  type     zipCode
  width    10
  help     "This is the ZIP code of the address of the CPOD site."
  pdf      text L 517.00 R 563.44 B 409.16 T 422.56 BL 412.20

field 26.
  label    "37. Police Jurisdiction"
  width    59
  help     "This is the police department, and division or region if applicable, with jurisdiction over the CPOD site."
  pdf      text L 289.00 R 563.44 B 390.68 T 404.20 BL 393.72

field 27.
  label    "38. Fire Jurisdiction"
  width    59
  help     "This is the fire department, and division or region if applicable, with jurisdiction over the CPOD site."
  pdf      text L 289.00 R 563.44 B 372.08 T 385.72 BL 375.24

field 28. defaultBody
  label    "39. Additional Information"
  type     multiline
  width    80
  help     "This is any additional pertinent information regarding the CPOD and its site."
  pdf      text L 169.48 R 563.44 B 341.60 T 367.24 BL 357.36

field 30.
  label    "41. Partner Point of Contact"
  width    28
  help     "This is the name and contact information of the contact person with the partner operating the CPOD."
  pdf      text L 175.36 R 303.76 B 305.72 T 319.12 BL 308.64

field 31.
  label    "42. Site Point of Contact"
  width    31
  help     "This is the name and contact information of the contact person responsible for the site hosting the CPOD."
  pdf      text L 428.32 R 563.44 B 305.72 T 319.12 BL 308.64

field 40.
  label    "51. Dimensions of Site in Feet"
  width    27
  help     "This is the dimensions of the CPOD site, in feet (e.g. \"200x150\")."
  pdf      text L 182.80 R 303.76 B 270.08 T 283.12 BL 272.88

field 41.
  label    "52. Size of Site in Acres"
  width    32
  help     "This is the size of the CPOD site in acres."
  pdf      text L 422.68 R 563.44 B 270.08 T 283.12 BL 272.88

field 42a.
  label    "53a. Access: Concrete"
  clabel   Concrete
  type     checkbox
  help     "This indicates that some access roads or walkways are concrete."
  pdf      if 42a. then cross L 173.28 R 181.08 B 255.24 T 263.04

field 42b.
  label    "53b. Access: Gravel Hard-Stand"
  clabel   "Gravel Hard-Stand"
  type     checkbox
  help     "This indicates that some access roads or walkways are gravel hard-stand."
  pdf      if 42b. then cross L 257.64 R 265.44 B 255.24 T 263.04

field 42c.
  label    "53c. Access: Paved"
  clabel   Paved
  type     checkbox
  help     "This indicates that some access roads or walkways are paved."
  pdf      if 42c. then cross L 387.96 R 395.76 B 255.24 T 263.04

field 42d.
  label    "53d. Access: Other"
  clabel   Other
  type     checkbox
  help     "This indicates that some access roads or walkways have other surfaces.  Give the details in the Additional Information field."
  pdf      if 42d. then cross L 460.68 R 468.48 B 255.24 T 263.04

field -
  label    "53. Access"
  type     checkboxGroup
  children 42a. 42b. 42c. 42d.

field 43.
  label    "54. Accessible at All Times"
  type     restricted
  choice   Yes
  choice   No
  help     "This indicates whether the site is accessible at all times."
  pdf      if 43.=Yes then circle X 191.64 Y 241.14 R 2.84
  pdf      if 43.=No then circle X 238.20 Y 241.20 R 2.72

field 44.
  label    "55. Access Controlled by Gate"
  type     restricted
  choice   Yes
  choice   No
  help     "This indicates whether site access is controlled by a gate."
  pdf      if 44.=Yes then circle X 191.64 Y 223.14 R 2.84
  pdf      if 44.=No then circle X 237.84 Y 223.14 R 2.84

field 45.
  label    "56. Site Contact if Gate is Closed"
  width    23
  help     "This gives the name and contact information of the person to contact for access if the gate is closed."
  pdf      text L 465.16 R 563.44 B 216.08 T 229.60 BL 219.12

field 46.
  label    "57. Location of Driveway(s)"
  width    82
  help     "This gives the locations of all driveways into the site."
  pdf      text L 172.00 R 563.44 B 198.32 T 211.60 BL 203.16

field 47.
  label    "58. Spike Strips at any of the driveways"
  type     restricted
  choice   Yes
  choice   No
  help     "This indicates whether any of the driveways have spike strips."
  pdf      if 47.=Yes then circle X 299.70 Y 188.40 R 2.90
  pdf      if 47.=No then circle X 346.20 Y 188.34 R 2.96

field 50a.
  label    "61a. Safety: Has perimeter fencing"
  clabel   "has perimeter fencing"
  type     checkbox
  help     "This indicates whether the site has perimeter fencing."
  pdf      if 50a. then cross L  70.08 R  77.88 B 135.36 T 143.16

field 50b.
  label    "61b. Safety: Has outside lighting"
  clabel   "has outside lighting"
  type     checkbox
  help     "This indicates whether the site has fixed lighting throughout all outside areas."
  pdf      if 50b. then cross L  70.08 R  77.88 B 119.88 T 127.68

field 50c.
  label    "61c. Safety: Has inside lighting"
  clabel   "has inside lighting"
  type     checkbox
  help     "This indicates whether the site has fixed lighting throughout all inside areas."
  pdf      if 50c. then cross L  70.08 R  77.88 B 104.28 T 112.08

field 50d.
  label    "61d. Safety: Monitored with CCTV"
  clabel   "monitored with CCTV"
  type     checkbox
  help     "This indicates whether the site is monitored using closed-circuit TV cameras."
  pdf      if 50d. then cross L  70.08 R  77.88 B  88.80 T  96.60

field 50e.
  label    "61e. Safety: Has PA system"
  clabel   "has PA system"
  type     checkbox
  help     "This indicates whether the site has a public address system installed."
  pdf      if 50e. then cross L 331.80 R 339.60 B 135.36 T 143.16

field 50f.
  label    "61f. Safety: Has covered areas"
  clabel   "has covered areas"
  type     checkbox
  help     "This indicates whether the site has covered areas."
  pdf      if 50f. then cross L 331.80 R 339.60 B 119.88 T 127.68

field 50g.
  label    "61g. Safety: Has fixed equipment"
  clabel   "has fixed equipment"
  type     checkbox
  help     "This indicates whether there is fixed or non-fixed equipment located on the site that may be difficult to move."
  pdf      if 50g. then cross L 331.80 R 339.60 B 104.28 T 112.08

field -
  label    "61. Safety"
  type     checkboxGroup
  children 50a. 50b. 50c. 50d. 50e. 50f. 50g.

field 51.
  label    "62. Perimeter Fencing Details"
  type     multiline
  width    80
  help     "This gives details of the perimeter fencing."
  pdf      text P 2 L 186.16 R 563.44 B 685.52 T 708.64 BL 700.08

field 52a.
  label    "63a. Accessibility: Wheelchair access"
  clabel   "wheelchair access"
  type     checkbox
  help     "This indicates whether there are sidewalks leading to the site that have wheelchair access."
  pdf      if 52a. then cross P 2 L 156.24 R 164.16 B 671.52 T 679.44

field 52b.
  label    "63b. Accessibility: Uneven surfaces"
  clabel   "uneven surfaces"
  type     checkbox
  help     "This indicates whether there are uneven surfaces leading up to the site."
  pdf      if 52b. then cross P 2 L 156.24 R 164.16 B 656.16 T 664.32

field 52c.
  label    "63c. Accessibility: Ramp from staff parking"
  clabel   "ramp from staff parking"
  type     checkbox
  help     "This indicates whether there is a ramp from the staff parking location leading up to the POD location."
  pdf      if 52c. then cross P 2 L 156.24 R 164.16 B 640.56 T 648.72

field -
  label    "63. Accessibility"
  type     checkboxGroup
  children 52a. 52b. 52c.

