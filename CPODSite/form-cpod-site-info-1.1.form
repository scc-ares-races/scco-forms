field 76b.
  label    "87b. Item 7: Starting Quantity"
  type     cardinalNumber
  presence if 76a. then required else blocked
  width    4
  help     "This is the quantity of the commodity that the CPOD site had when it opened.  It is required."
  pdf      text P 2 L 198.40 R 246.64 B 236.96 T 250.72 BL 240.12

field 76c.
  label    "87c. Item 7: Qty Distributed"
  type     cardinalNumber
  presence if 76a. then required else blocked
  width    4
  help     "This is the quantity of the commodity that the CPOD site has distributed to visitors.  It is required."
  pdf      text P 2 L 352.24 R 410.08 B 236.96 T 250.72 BL 240.12

field 76d.
  label    "87d. Item 7: Qty Available"
  type     cardinalNumber
  presence if 76a. then required else blocked
  width    4
  help     "This is the quantity of the commodity that the CPOD site has available for distribution.  It is required."
  pdf      text P 2 L 508.00 R 563.44 B 236.96 T 250.72 BL 240.12

field 77a.
  label    "88a.. Item 8: Type of Commodity"
  presence if 76a. then optional else blocked
  width    999
  help     "This is the type of a commodity distributed at the CPOD site."
  pdf      text P 2 L 208.72 R 563.44 B 208.64 T 231.76 BL 223.08

field 77b.
  label    "88b. Item 8: Starting Quantity"
  type     cardinalNumber
  presence if 77a. then required else blocked
  width    4
  help     "This is the quantity of the commodity that the CPOD site had when it opened.  It is required."
  pdf      text P 2 L 198.40 R 246.64 B 190.64 T 204.16 BL 193.68

field 77c.
  label    "88c. Item 8: Qty Distributed"
  type     cardinalNumber
  presence if 77a. then required else blocked
  width    4
  help     "This is the quantity of the commodity that the CPOD site has distributed to visitors.  It is required."
  pdf      text P 2 L 352.24 R 410.08 B 190.64 T 204.16 BL 193.68

field 77d.
  label    "88d. Item 8: Qty Available"
  type     cardinalNumber
  presence if 77a. then required else blocked
  width    4
  help     "This is the quantity of the commodity that the CPOD site has available for distribution.  It is required."
  pdf      text P 2 L 508.00 R 563.44 B 190.64 T 204.16 BL 193.68

field OpRelayRcvd
  label    "Operator: Relay Received"
  width    36
  help     "This is the name of the station from which this message was directly received.  It is filled in for messages that go through a relay station."
  pdf      text P 2 L 108.88 R 320.56 B 146.96 T 161.44 BL 150.48

field OpRelaySent
  label    "Operator: Relay Sent"
  width    36
  help     "This is the name of the station to which this message was directly sent.  It is filled in for messages that go through a relay station."
  pdf      text P 2 L 354.88 R 564.88 B 146.96 T 161.44 BL 150.48

field OpName operatorName
  label    "Operator: Name"
  presence required
  pdf      text P 2 L  74.80 R 204.88 B 128.00 T 142.48 BL 131.52

field OpCall operatorCall
  label    "Operator: Call Sign"
  presence required
  pdf      text P 2 L 256.96 R 330.88 B 128.00 T 142.48 BL 131.52

field -
  label    Operator
  type     join
  children OpName OpCall

field OpDate operatorDate
  label    "Operator: Date"
  type     date
  pdf      text P 2 L 366.40 R 429.76 B 128.00 T 142.48 BL 131.52

field OpTime operatorTime
  label    "Operator: Time"
  type     time
  pdf      text P 2 L 493.60 R 564.88 B 128.00 T 142.48 BL 131.52

field -
  label    "Operator: Date/Time"
  type     dateTime
  children OpDate OpTime

field -
  pdf      box L 279.96 R 333.48 B  18.36 T  30.00 F FFFFFF
  pdf      box P 2 L 279.36 R 334.80 B  17.04 T  29.52 F FFFFFF
