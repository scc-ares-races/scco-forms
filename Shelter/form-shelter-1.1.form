addon    SCCoPIFO
html     form-shelter.html
version  1.1
title    Shelter Form
indef    a shelter form
create   Shelter sh
pdfFile  Shelter_v20260307.pdf
deftext  FT Times-Roman FS 12.0 MS 8.0 LH 1.15 A lF WR f CL t C 000099

field MsgNo originMessageID
  label    "1. Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 229.00 R 326.08 B 713.00 T 730.96 BL 718.32

field DestMsgNo destinationMessageID
  label    "2. Destination Message Number"
  type     messageID
  pdf      text L 437.08 R 564.76 B 713.00 T 730.96 BL 718.32

field 1a. messageDate
  label    "3. Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  81.04 R 132.76 B 658.88 T 678.76 BL 665.04

field 1b. messageTime
  label    "4. Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 181.12 R 236.32 B 658.88 T 678.76 BL 665.04

field -
  label    "3-4. Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    "5. Handling"
  type     restricted
  value    PRIORITY
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 309.84 Y 669.12 R 2.72
  pdf      if 5.=PRIORITY then circle X 406.86 Y 669.12 R 2.90
  pdf      if 5.=ROUTINE then circle X 487.92 Y 669.12 R 2.72

field 7a. toICSPosition
  label    "6. To ICS Position"
  value    "Care & Shelter Unit"
  choice   Care & Shelter Unit
  choice   Mass Care & Emerg. Asst. Branch
  choice   Operations
  presence required
  width    30
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 142.12 R 299.32 B 640.88 T 653.92 BL 643.68

field 7b. toLocation
  label    "7. To Location"
  value    "County EOC"
  presence required
  width    32
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 142.12 R 299.32 B 622.88 T 635.92 BL 625.68

field 7c. toName
  label    "8. To Name"
  width    34
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 142.12 R 299.32 B 604.88 T 617.92 BL 607.68

field 7d. toContact
  label    "9. To Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 142.12 R 299.32 B 582.68 T 599.92 BL 587.64

field 8a. fromICSPosition
  label    "10. From ICS Position"
  presence required
  width    30
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 403.96 R 563.44 B 640.88 T 653.92 BL 643.68

field 8b. fromLocation
  label    "11. From Location"
  presence required
  width    32
  help     "This is the location of the message author.  It is required."
  pdf      text L 403.96 R 563.44 B 622.88 T 635.92 BL 625.68

field 8c. fromName
  label    "12. From Name"
  width    34
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 403.96 R 563.44 B 604.88 T 617.92 BL 607.68

field 8d. fromContact
  label    "13. From Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 403.96 R 563.44 B 582.68 T 599.92 BL 587.64

field 20.
  label    "21. Jurisdiction"
  choice   Campbell
  choice   Cupertino
  choice   Gilroy
  choice   Los Altos
  choice   Los Altos Hills
  choice   Los Gatos
  choice   Milpitas
  choice   Monte Sereno
  choice   Morgan Hill
  choice   Mountain View
  choice   Palo Alto
  choice   San Jose
  choice   Santa Clara (City)
  choice   Saratoga
  choice   Sunnyvale
  choice   Santa Clara County
  choice   County unincorporated
  presence required
  help     "This is the name of the jurisdiction originating the shelter.  It is required."
  pdf      text L 127.00 R 563.44 B 544.52 T 558.04 BL 547.56

field 21. messageSummary
  label    "22. Shelter Name"
  presence required
  width    94
  help     "This is the name of the shelter being described.  It is required."
  pdf      text L 127.00 R 563.44 B 526.04 T 539.56 BL 529.08

field 22.
  label    "23. Location"
  presence required
  width    94
  help     "This is the location of the shelter.  It is required."
  pdf      text L 127.00 R 563.44 B 507.44 T 521.08 BL 510.48

field 23a.
  label    "24a. Type: Congregate"
  clabel   Congregate
  type     checkbox
  help     "This indicates that the shelter is a congregate shelter."
  pdf      if 23a. then cross L 115.80 R 123.60 B 493.08 T 500.88

field 23b.
  label    "24b. Type: Non-Congregate"
  clabel   Non-Congregate
  type     checkbox
  help     "This indicates that the shelter is a non-congregate shelter."
  pdf      if 23b. then cross L 115.68 R 123.48 B 477.60 T 485.40

field 23c.
  label    "24c. Type: Temporary Evacuation Point"
  clabel   "Temporary Evacuation Point"
  type     checkbox
  help     "This indicates that the shelter is a temporary evacuation point."
  pdf      if 23c. then cross L 223.80 R 231.60 B 493.08 T 500.88

field 23d.
  label    "24d. Type: Pets Accepted"
  clabel   "Pets Accepted"
  type     checkbox
  help     "This indicates that the shelter accepts pets."
  pdf      if 23d. then cross L 223.80 R 231.60 B 477.60 T 485.40

field 23e.
  label    "24e. Type: Large Animals"
  clabel   "Large Animals"
  type     checkbox
  help     "This indicates that the shelter accepts large animals."
  pdf      if 23e. then cross L 403.80 R 411.60 B 493.08 T 500.88

field -
  label    "24. Type"
  type     checkboxGroup
  children 23a. 23b. 23c. 23d. 23e.
  presence required

field 24.
  label    "25. Shelter Status"
  type     restricted
  choice   Setup
  choice   Open
  choice   Full
  choice   Closed
  presence required
  help     "This indicates the status of the shelter.  Setup means setup is in progress, not yet accepting guests.  This field is required."
  pdf      if 24.=Setup then circle X 154.32 Y 466.02 R 2.00
  pdf      if 24.=Full then circle X 370.32 Y 466.02 R 2.00
  pdf      if 24.=Open then circle X 154.32 Y 452.58 R 2.12
  pdf      if 24.=Closed then circle X 370.32 Y 452.58 R 2.00

field 25a.
  label    "26a. Resources: Warming Center"
  clabel   "Warming Center"
  type     checkbox
  help     "This indicate that the shelter is a warming center."
  pdf      if 25a. then cross L 115.80 R 123.60 B 433.20 T 441.00

field 25b.
  label    "26b. Resources: Cooling Center"
  clabel   "Cooling Center"
  type     checkbox
  help     "This indicates that the shelter is a cooling center."
  pdf      if 25b. then cross L 115.68 R 123.48 B 417.60 T 425.40

field 25c.
  label    "26c. Resources: Food & Drink"
  clabel   "Food & Drink"
  type     checkbox
  help     "This indicates that the shelter offers food and drink."
  pdf      if 25c. then cross L 295.80 R 303.60 B 433.20 T 441.00

field 25d.
  label    "26d. Resources: Charging Stations"
  clabel   "Charging Stations"
  type     checkbox
  help     "This indicates that the shelter has charging stations."
  pdf      if 25d. then cross L 295.80 R 303.60 B 417.60 T 425.40

field -
  label    "26. Resources"
  type     checkboxGroup
  children 25a. 25b. 25c. 25d.

field 26. defaultBody
  label    "27. Notes"
  type     multiline
  width    108
  help     "This field contains notes about the shelter."
  pdf      text L  91.36 R 563.44 B 347.24 T 410.56 BL 402.00

field 27.
  label    "28. ADA Compliant?"
  type     restricted
  choice   Yes
  choice   No
  help     "This indicates whether the shelter is ADA compliant."
  pdf      if 27.=Yes then circle X 154.32 Y 335.94 R 2.00
  pdf      if 27.=No then circle X 226.32 Y 335.94 R 1.88

field 28.
  label    "29. Pets Allowed?"
  type     restricted
  choice   Yes
  choice   No
  help     "This indicates whether the shelter allows pets."
  pdf      if 28.=Yes then circle X 424.32 Y 335.94 R 2.00
  pdf      if 28.=No then circle X 496.32 Y 336.00 R 1.76

field 29.
  label    "30. Maximum Capacity"
  type     cardinalNumber
  presence required
  width    3
  help     "This is the maximum capacity of the shelter.  It is required."
  pdf      text L 152.56 R 215.08 B 310.40 T 323.92 BL 313.44

field 30.
  label    "31. Total Registered"
  type     cardinalNumber
  presence required
  width    3
  help     "This is the number of people currently registered in the shelter.  It is required."
  pdf      text L 320.44 R 392.08 B 310.40 T 323.92 BL 313.44

field 31.
  label    "32. Cot Numbers"
  type     cardinalNumber
  presence required
  width    3
  help     "This is the number of cots in the shelter.  It is required."
  pdf      text L 482.68 R 563.44 B 310.40 T 323.92 BL 313.44

field 32.
  label    "33. AFN Considerations"
  type     multiline
  width    108
  help     "This field describes shelter considerations relating to access and functional needs."
  pdf      text L 154.24 R 563.44 B 255.68 T 305.44 BL 296.88

field 40.
  label    "41. Managed By"
  type     restricted
  mchoice  ARC American Red Cross
  choice   Government
  choice   Community
  choice   Private
  choice   Other
  presence required
  help     "This indicates what type of entity the shelter is managed by.  It is required."
  pdf      if 40.=ARC then circle X 154.32 Y 219.18 R 1.88
  pdf      if 40.=Government then circle X 298.32 Y 219.18 R 2.00
  pdf      if 40.=Other then circle X 442.32 Y 219.18 R 2.00
  pdf      if 40.=Private then circle X 154.32 Y 205.74 R 2.12
  pdf      if 40.=Community then circle X 298.32 Y 205.74 R 2.00

field 41.
  label    "42. Primary Contact Name"
  presence required
  width    30
  help     "This is the name of the primary contact for the shelter.  It is required."
  pdf      text L 168.40 R 303.76 B 182.24 T 195.76 BL 185.28

field 42.
  label    "43. Primary Contact Phone"
  type     phoneNumber
  presence required
  help     "This is the phone number of the primary contact for the shelter.  It is required."
  pdf      text L 480.28 R 563.44 B 182.24 T 195.76 BL 185.28

field 43.
  label    "44. Primary Contact Email"
  width    84
  help     "This is the email address of the primary contact for the shelter."
  pdf      text L 168.40 R 563.44 B 163.76 T 177.28 BL 166.80

field OpRelayRcvd
  label    "Operator: Relay Received"
  width    36
  help     "This is the name of the station from which this message was directly received.  It is filled in for messages that go through a relay station."
  pdf      text L 110.08 R 316.00 B 122.72 T 137.08 BL 126.12

field OpRelaySent
  label    "Operator: Relay Sent"
  width    36
  help     "This is the name of the station to which this message was directly sent.  It is filled in for messages that go through a relay station."
  pdf      text L 350.44 R 564.76 B 122.72 T 137.08 BL 126.12

field OpName operatorName
  label    "Operator: Name"
  presence required
  pdf      text L  74.92 R 244.00 B 103.76 T 118.24 BL 107.28

field OpCall operatorCall
  label    "Operator: Call Sign"
  presence required
  pdf      text L 296.44 R 361.00 B 103.76 T 118.24 BL 107.28

field -
  label    Operator
  type     join
  children OpName OpCall

field OpDate operatorDate
  label    "Operator: Date"
  type     date
  pdf      text L 396.64 R 469.00 B 103.76 T 118.24 BL 107.28

field OpTime operatorTime
  label    "Operator: Time"
  type     time
  pdf      text L 532.96 R 564.76 B 103.76 T 118.24 BL 107.28

field -
  label    "Operator: Date/Time"
  type     dateTime
  children OpDate OpTime

field -
  pdf      box L 280.44 R 333.36 B  48.96 T  60.00 F FFFFFF
