field 15.10c.
  label    "68b. Orthopedics: Reason Closed"
  presence if 15.10.=N then optional else blocked
  help     "This is the reason that orthopedics services are not available.  It can be set only when \"Orthopedics: Available Now\" is \"No\"."
  pdf      text P 2 L 292.72 R 479.20 B 247.76 T 265.84 BL 252.48

field 15.10d.
  label    "68c. Orthopedics: Expected Reopening"
  type     date
  presence if 15.10.=N then optional else blocked
  help     "This is the date when orthopedics services are expected to reopen, in MM/DD/YYYY format.  It can be set only when \"Orthopedics: Available Now\" is \"No\"."
  pdf      text P 2 L 498.40 R 572.56 B 247.76 T 265.84 BL 252.48

