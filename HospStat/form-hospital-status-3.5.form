  type     date
  presence if 15.11.=N then optional else blocked
  help     "This is the date when pediatrics services are expected to reopen, in MM/DD/YYYY format.  It can be set only when \"Pediatrics: Available Now\" is \"No\"."
  pdf      text P 2 L 498.40 R 572.56 B 225.20 T 243.28 BL 230.16

field 15.12.
  label    "70a. Surgery: Available Now"
  type     restricted
  mchoice  Y Yes
  mchoice  N No
  help     "This indicates the availability of surgery services."
  pdf      if 15.12.=Y then circle P 2 X 211.32 Y 212.04 R 2.84
  pdf      if 15.12.=N then circle P 2 X 244.44 Y 212.10 R 2.72

field 15.12c.
  label    "70b. Surgery: Reason Closed"
  presence if 15.12.=N then optional else blocked
  help     "This is the reason that surgery services are not available.  It can be set only when \"Surgery: Available Now\" is \"No\"."
