addon    SCCoPIFO
html     form-hospital-status.html
version  3.5
title    Hospital Status Form
indef    a hospital status form
create   HospStat hs
pdfFile  XSC_Hospital_Status_v20260313.pdf

field MsgNo originMessageID
  label    "1. Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 228.40 R 348.88 B 702.80 T 717.52 BL 706.32
  pdf      text P 2 L 467.96 R 576.36 B 741.08 T 762.00 BL 745.44

field DestMsgNo destinationMessageID
  label    "2. Destination Message Number"
  type     messageID
  pdf      text L 456.28 R 573.76 B 702.80 T 717.52 BL 706.32

field 1a. messageDate
  label    "3. Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  79.28 R 137.20 B 654.32 T 677.20 BL 661.92

field 1b. messageTime
  label    "4. Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 180.56 R 231.76 B 654.32 T 677.20 BL 661.92

field -
  label    "3-4. Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    "5. Handling"
  type     restricted
  value    IMMEDIATE
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 305.16 Y 665.94 R 2.60
  pdf      if 5.=PRIORITY then  circle X 408.60 Y 665.88 R 2.72
  pdf      if 5.=ROUTINE then   circle X 496.02 Y 665.94 R 2.78

field 7a. toICSPosition
  label    "6. To ICS Position"
  value    "EMS Unit"
  choice   EMS Unit
  choice   Medical Health Branch
  choice   Operations Section
  presence required
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 137.92 R 299.92 B 632.24 T 649.84 BL 637.20

field 7b. toLocation
  label    "7. To Location"
  value    PHDOC
  choice   PHDOC
  choice   County EOC
  presence required
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 137.92 R 299.92 B 609.68 T 627.76 BL 614.88

field 7c. toName
  label    "8. To Name"
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 137.92 R 299.92 B 587.12 T 605.20 BL 592.32

field 7d. toContact
  label    "9. To Contact Info"
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 137.92 R 299.92 B 564.56 T 582.64 BL 569.76

field 8a. fromICSPosition
  label    "10. From ICS Position"
  presence required
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 409.12 R 572.56 B 632.24 T 649.84 BL 637.20

field 8b. fromLocation
  label    "11. From Location"
  presence required
  help     "This is the location of the message author.  It is required."
  pdf      text L 409.12 R 572.56 B 609.68 T 627.76 BL 614.88

field 8c. fromName
  label    "12. From Name"
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 409.12 R 572.56 B 587.12 T 605.20 BL 592.32

field 8d. fromContact
  label    "13. From Contact Info"
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 409.12 R 572.56 B 564.56 T 582.64 BL 569.76

field 20. messageSummary
  label    "14. Hospital Name"
  type     restricted
  choice   El Camino Hospital Los Gatos
  choice   El Camino Hospital Mountain View
  choice   Good Samaritan Hospital
  choice   Kaiser San Jose Medical Center
  choice   Kaiser Santa Clara Hospital
  choice   Lucile Packard Children's Hospital
  choice   O'Connor Hospital
  choice   Palo Alto Veterans Hospital
  choice   Regional San Jose Medical Center
  choice   Saint Louise Regional Hospital
  choice   Stanford Hospital
  choice   Stanford School of Medicine
  choice   Valley Medical Center
  presence required
  help     "This is the name of the hospital reporting status.  It is required."
  pdf      text L 137.92 R 572.56 B 541.76 T 559.60 BL 546.72

field 12.1.
  label    "21. Diversion"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  Open b. Open
  mchoice  "Diverting Ambulances" c. Diverting Ambulances
  mchoice  "Internal Disaster" d. Internal Disaster
  mchoice  "Specialty Bypass" e. Specialty Bypass
  help     "This indicates the diversion status of the hospital."
  pdf      if 12.1.=Unknown then                circle X 190.86 Y 513.06 R 2.66
  pdf      if 12.1.=Open then                   circle X 307.86 Y 513.06 R 2.66
  pdf      if 12.1.="Diverting Ambulances" then circle X 433.86 Y 513.00 R 2.78
  pdf      if 12.1.="Internal Disaster" then    circle X 190.86 Y 497.70 R 2.54
  pdf      if 12.1.="Specialty Bypass" then     circle X 307.86 Y 497.64 R 2.78

field 12.1c.
  label    "21f. Diversion: Comment"
  help     "This is a comment on the diversion status."
  pdf      text L 198.40 R 572.56 B 475.04 T 487.12 BL 478.56

field 12.2.
  label    "22. Decon"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  "Not Available" b. Not Available
  mchoice  Active c. Active
  mchoice  Available d. Available
  help     "This indicates the decontamination status of the hospital."
  pdf      if 12.2.=Unknown then         circle X 190.86 Y 464.82 R 2.66
  pdf      if 12.2.="Not Available" then circle X 307.86 Y 464.76 R 2.78
  pdf      if 12.2.=Active then          circle X 433.86 Y 464.76 R 2.78
  pdf      if 12.2.=Available then       circle X 190.86 Y 449.16 R 2.78

field 12.2c.
  label    "22e. Decon: Comment"
  help     "This is a comment on the decontamination status."
  pdf      text L 198.40 R 572.56 B 426.08 T 438.64 BL 430.08

field 12.3.
  label    "23. Command Center"
  type     restricted
  mchoice  Activated a. Activated
  mchoice  Monitoring b. Monitoring
  mchoice  "Not Activated" c. Not Activated
  help     "This indicates whether the hospital command center is activated."
  pdf      if 12.3.=Activated then       circle X 190.86 Y 415.62 R 2.66
  pdf      if 12.3.=Monitoring then      circle X 307.80 Y 415.56 R 2.84
  pdf      if 12.3.="Not Activated" then circle X 433.86 Y 415.56 R 2.78

field 12.3c.
  label    "23d. Command Center: Comment"
  help     "This is a comment on the command center activation."
  pdf      text L 198.40 R 572.56 B 390.32 T 402.16 BL 393.60

field 12.4.
  label    "24. Morgue"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  Open b. Open
  mchoice  Full c. Full
  help     "This indicates the status of the hospital morgue."
  pdf      if 12.4.=Unknown then circle X 190.86 Y 379.86 R 2.66
  pdf      if 12.4.=Open then    circle X 307.86 Y 379.80 R 2.78
  pdf      if 12.4.=Full then    circle X 433.86 Y 379.80 R 2.78

field 12.4c.
  label    "24d. Morgue: Comment"
  help     "This is a comment on the morgue status."
  pdf      text L 198.40 R 572.56 B 352.16 T 364.00 BL 355.44

field 12.5.
  label    "25. Power"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  Normal b. Normal
  mchoice  Generator c. Generator
  mchoice  None d. None
  help     "This indicates the power supply for the hospital."
  pdf      if 12.5.=Unknown then   circle X 190.86 Y 341.64 R 2.78
  pdf      if 12.5.=Normal then    circle X 307.86 Y 341.70 R 2.66
  pdf      if 12.5.=Generator then circle X 433.86 Y 341.64 R 2.78
  pdf      if 12.5.=None then      circle X 190.80 Y 326.28 R 2.84

field 12.5f.
  label    "25e. Hours of Fuel Remaining"
  type     realNumber
  help     "This is the number of hours of fuel remaining for the hospital generator."
  pdf      text L 264.76 R 572.56 B 306.32 T 315.76 BL 307.20

field 12.5c.
  label    "25f. Power: Comment"
  help     "This is a comment on the power supply."
  pdf      text L 198.40 R 572.56 B 289.76 T 301.84 BL 293.28

field 12.6.
  label    "26. Building"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  "Restricted Use" b. Restricted Use
  mchoice  "Unsafe to Occupy" c. Unsafe to Occupy
  mchoice  "Not Inspected" d. Not Inspected
  mchoice  "Safe to Occupy" e. Safe to Occupy
  mchoice  Normal f. Normal
  mchoice  Compromised g. Compromised
  mchoice  Evacuating h. Evacuating
  mchoice  Closed i. Closed
  help     "This indicates the structural safety of the hospital building."
  pdf      if 12.6.=Unknown then            circle X 190.86 Y 279.48 R 2.78
  pdf      if 12.6.="Restricted Use" then   circle X 307.86 Y 279.54 R 2.66
  pdf      if 12.6.="Unsafe to Occupy" then circle X 433.86 Y 279.54 R 2.54
  pdf      if 12.6.="Not Inspected" then    circle X 190.86 Y 263.88 R 2.78
  pdf      if 12.6.="Safe to Occupy" then   circle X 307.80 Y 263.88 R 2.84
  pdf      if 12.6.=Normal then             circle X 433.86 Y 263.94 R 2.66
  pdf      if 12.6.=Compromised then        circle X 190.86 Y 248.34 R 2.54
  pdf      if 12.6.=Evacuating then         circle X 308.82 Y 248.28 R 2.90
  pdf      if 12.6.=Closed then             circle X 433.86 Y 248.34 R 2.66

field 12.6c.
  label    "26j. Building: Comment"
  help     "This is a comment on the building safety status."
  pdf      text L 198.40 R 572.56 B 225.68 T 237.52 BL 228.96

field 12.7.
  label    "27. Security"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  Normal b. Normal
  mchoice  Elevated c. Elevated
  mchoice  "Restricted Access" d. Restricted Access
  mchoice  Lockdown e. Lockdown
  help     "This indicates the security level of the hospital."
  pdf      if 12.7.=Unknown then             circle X 190.86 Y 215.16 R 2.78
  pdf      if 12.7.=Normal then              circle X 307.86 Y 215.22 R 2.54
  pdf      if 12.7.=Elevated then            circle X 433.86 Y 215.22 R 2.66
  pdf      if 12.7.="Restricted Access" then circle X 190.80 Y 199.80 R 2.84
  pdf      if 12.7.=Lockdown then            circle X 307.86 Y 199.80 R 2.78

field 12.7c.
  label    "27f. Security: Comment"
  help     "This is a comment on the security level."
  pdf      text L 198.40 R 572.56 B 177.44 T 189.28 BL 180.72

field 12.8.
  label    "28. Staffing"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  Adequate b. Adequate
  mchoice  Insufficient c. Insufficient
  help     "This indicates the staffing level of the hospital."
  pdf      if 12.8.=Unknown then      circle X 190.80 Y 166.92 R 2.84
  pdf      if 12.8.=Adequate then     circle X 307.86 Y 166.98 R 2.66
  pdf      if 12.8.=Insufficient then circle X 433.86 Y 166.98 R 2.54


field 12.8c.
  label    "28d. Staffing: Comment"
  help     "This is a comment on the staffing level."
  pdf      text L 198.40 R 572.56 B 140.72 T 152.56 BL 144.00

field 12.9.
  label    "29. Medical Facility Supplies"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  Adequate b. Adequate
  mchoice  Insufficient c. Insufficient
  help     "This indicates the sufficiency of medical facility supplies."
  pdf      if 12.9.=Unknown then      circle X 190.86 Y 129.78 R 2.66
  pdf      if 12.9.=Adequate then     circle X 307.86 Y 129.78 R 2.66
  pdf      if 12.9.=Insufficient then circle X 433.86 Y 129.78 R 2.54

field 12.9c.
  label    "29d. Medical Supplies: Comment"
  help     "This is a comment on the medical facility supplies status."
  pdf      text L 198.40 R 572.56 B 102.80 T 114.64 BL 106.08

field 12.10.
  label    "30. Clinical Supplies"
  type     restricted
  mchoice  Unknown a. Unknown
  mchoice  Adequate b. Adequate
  mchoice  Insufficient c. Insufficient
