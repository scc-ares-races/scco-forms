  pdf      text P 2 L 498.40 R 572.56 B 202.88 T 220.72 BL 207.60

field 16.
  label    "81. Evacuating"
  type     restricted
  mchoice  Y Yes
  mchoice  N No
  help     "This indicates whether the hospital is currently being evacuated."
  pdf      if 16.=N then circle P 2 X 191.52 Y 171.00 R 2.84
  pdf      if 16.=Y then circle P 2 X 223.44 Y 171.06 R 2.84

field 16a.
  label    "82. Ambulatory Patients"
  type     cardinalNumber
  presence if 16.=Y then optional else blocked
  help     "This is the number of ambulatory patients that need to be evacuated. It can be set only when \"Evacuating\" is \"Yes\"."
  pdf      text P 2 L 251.92 R 572.56 B 144.56 T 156.64 BL 146.88

field 16b.
  label    "83. Non-Ambulatory Patients"
  type     cardinalNumber
  presence if 16.=Y then optional else blocked
