field 13. defaultBody
  label   "31. Resource Impacts/Needs"
  type    multiline
  help    "This contains general comments on hospital resources."
  pdf      text P 2 L 197.92 R 572.56 B 711.92 T 740.08 BL 731.52

field 14.6.
  label    "41. Overall Hospital Census"
  help     "This is the number of occupied beds / the total number of staffed beds."
