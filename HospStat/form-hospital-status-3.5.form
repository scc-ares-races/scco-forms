field 14.9.
  label    "47. Longest Boarding Time (hours)"
  type     cardinalNumber
  help     "This is the longest patient boarding time in hours."
  pdf      text P 2 L 224.80 R 572.56 B 547.52 T 561.04 BL 550.56

field 17a.
  label    "51a. Trends: None"
  type     checkbox
  help     "This indicates that no trends or syndromes are observed."
  pdf      if 17a. then cross P 2 L 258.84 R 266.64 B 515.40 T 522.96

field 17b.
  label    "51b. Trends: Flu-like / RSV"
  type     checkbox
  help     "This indicates that a trend of Flu-like / RSV cases is observed."
  pdf      if 17b. then cross P 2 L 344.40 R 352.20 B 515.40 T 522.96

field 17c.
  label    "51c. Trends: COVID-19"
  type     checkbox
  help     "This indicates that a trend of COVID-19 cases is observed."
  pdf      if 17c. then cross P 2 L 456.96 R 464.64 B 515.40 T 522.96

field 17d.
  label    "51d. Trends: Cardiac"
  type     checkbox
  help     "This indicates that a trend of cardiac cases is observed."
  pdf      if 17d. then cross P 2 L 258.96 R 266.64 B 499.80 T 507.36

field 17e.
  label    "51e. Trends: Trauma"
  type     checkbox
  help     "This indicates that a trend of trauma cases is observed."
  pdf      if 17e. then cross P 2 L 344.40 R 352.20 B 499.80 T 507.36

field 17f.
  label    "51f. Trends: Behavioral"
  type     checkbox
  help     "This indicates that a trend of behavioral health cases is observed."
  pdf      if 17f. then cross P 2 L 456.96 R 464.64 B 499.80 T 507.36

field 17g.
  label    "51g. Trends: Other"
  type     checkbox
  help     "This indicates that a different trend or syndrome is observed. (Describe in the comments.)"
  pdf      if 17g. then cross P 2 L 258.96 R 266.64 B 484.20 T 491.76

field -
  label    "51. Trends / Syndromes"
  type     checkboxGroup
  children 17a. 17b. 17c. 17d. 17e. 17f. 17g.

field 15.1.
  label    "61a. Cardiology: Available Now"
  type     restricted
  mchoice  Y Yes
  mchoice  N No
  help     "This indicates the availability of cardiology services."
  pdf      if 15.1.=Y then  circle P 2 X 211.32 Y 420.36 R 2.72
  pdf      if 15.1.=N then  circle P 2 X 244.44 Y 420.36 R 2.84

field 15.1c.
  label    "61b. Cardiology: Reason Closed"
  presence if 15.1.=N then optional else blocked
  help     "This is the reason that cardiology services are not available.  It can be set only when \"Cardiology: Available Now\" is \"No\"."
  pdf      text P 2 L 292.72 R 479.20 B 410.48 T 429.52 BL 415.92

