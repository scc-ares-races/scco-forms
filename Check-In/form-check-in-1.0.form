addon    SCCoPIFO
html     form-check-in.html
version  1.0
title    Check-In Message
indef    a check-in message
create   Check-In ci

render_summary "Check-In <if:taccall>{{taccall}}, {{tacname}}</if:taccall><ifnot:taccall>{{opcall}}, {{opname}}</ifnot:taccall>"
render_body    "Check-In <if:taccall>{{taccall}}, {{tacname}}\n</if:taccall>{{opcall}}, {{opname}}"

field MsgNo originMessageID
  label    "Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."

field DestMsgNo destinationMessageID
  label    "Destination Message Number"
  type     messageID

field - handling
  type     static
  value    ROUTINE

field opcall operatorCall
  label    "Operator Call Sign"
  type     fccCallSign
  presence required
  help     "This is the FCC call sign assigned to the operator of the station.  It is required."

field opname operatorName
  label    "Operator Name"
  presence required
  help     "This is the name of the operator of the station.  It is required."

field -
  label    Operator
  type     join
  children opname opcall

field taccall tacticalCall
  label    "Tactical Call Sign"
  type     tacticalCallSign
  help     "This is the tactical call sign assigned to the station being operated, if any.  It is expected to be five or six letters or digits, starting with a letter."

field tacname tacticalName
  label    "Tactical Station Name"
  presence if taccall then required else blocked
  help     "This is the name of the station being operated.  It must be set when the Tactical Call Sign is set."

field -
  label    "Tactical Station"
  type     join
  children tacname taccall
