addon    SCCoPIFO
html     form-windshield-survey.html
version  1.1
title    Windshield Survey Form
indef    a windshield survey form
create   WSSurvey w
pdfFile  Windshield_Survey_v20260307.pdf
deftext  FT Times-Roman FS 12.0 MS 8.0 LH 1.15 A lF WR f CL t C 000099

field MsgNo originMessageID
  label    "1. Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 234.40 R 342.16 B 713.00 T 730.96 BL 718.32

field DestMsgNo destinationMessageID
  label    "2. Destination Message Number"
  type     messageID
  pdf      text L 453.16 R 564.76 B 713.00 T 730.96 BL 718.32

field 1a. messageDate
  label    "3. Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  81.04 R 132.76 B 656.12 T 676.12 BL 662.40

field 1b. messageTime
  label    "4. Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 181.12 R 236.32 B 656.12 T 676.12 BL 662.40

field -
  label    "3-4. Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    "5. Handling"
  type     restricted
  value    ROUTINE
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 309.84 Y 666.48 R 2.72
  pdf      if 5.=PRIORITY then circle X 406.80 Y 666.42 R 2.84
  pdf      if 5.=ROUTINE then circle X 487.92 Y 666.42 R 2.84

field 7a. toICSPosition
  label    "6. To ICS Position"
  value    "Damage/Safety Assessment Group"
  choice   Damage/Safety Assessment Group
  choice   Construction & Eng. Branch
  choice   Operations
  presence required
  width    30
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 142.12 R 299.32 B 638.12 T 651.28 BL 641.04

field 7b. toLocation
  label    "7. To Location"
  value    "County EOC"
  presence required
  width    32
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 142.12 R 299.32 B 620.12 T 633.28 BL 623.04

field 7c. toName
  label    "8. To Name"
  width    34
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 142.12 R 299.32 B 602.12 T 615.28 BL 605.04

field 7d. toContact
  label    "9. To Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 142.12 R 299.32 B 580.16 T 597.28 BL 585.00

field 8a. fromICSPosition
  label    "10. From ICS Position"
  presence required
  width    30
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 403.96 R 563.44 B 638.12 T 651.28 BL 641.04

field 8b. fromLocation
  label    "11. From Location"
  presence required
  width    32
  help     "This is the location of the message author.  It is required."
  pdf      text L 403.96 R 563.44 B 620.12 T 633.28 BL 623.04

field 8c. fromName
  label    "12. From Name"
  width    34
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 403.96 R 563.44 B 602.12 T 615.28 BL 605.04

field 8d. fromContact
  label    "13. From Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 403.96 R 563.44 B 580.16 T 597.28 BL 585.00

field 20.
  label    "21. Jurisdiction"
  choice   Campbell
  choice   Cupertino
  choice   Gilroy
  choice   Los Altos
  choice   Los Altos Hills
  choice   Los Gatos
  choice   Milpitas
  choice   Monte Sereno
  choice   Morgan Hill
  choice   Mountain View
  choice   Palo Alto
  choice   San Jose
  choice   Santa Clara (City)
  choice   Saratoga
  choice   Sunnyvale
  choice   Santa Clara County
  choice   County unincorporated
  presence required
  help     "This is the name of the jurisdiction where the windshield survey was performed.  It is required."
  pdf      text L 116.44 R 563.44 B 543.44 T 556.96 BL 546.48

field 21.
  label    "22. Team"
  presence required
  width    95
  help     "This is the name of the team (or individual) who performed the windshield survey.  It is required."
  pdf      text L 116.44 R 563.44 B 525.32 T 538.48 BL 528.12

field 22. messageSummary
  label    "23. Location"
  presence required
  width    95
  help     "This is the location that was surveyed.  It should be unique among all windshield survey reports in the jurisdiction.  It is required."
  pdf      text L 116.44 R 563.44 B 508.16 T 520.36 BL 510.60

field 23a.
  label    "24. Item: Building"
  type     checkbox
  help     "This indicates that the item surveyed was a building.  At least one item type is required."
  pdf      if 23a. then cross L 187.80 R 195.60 B 493.08 T 500.88

field 23b.
  label    "24. Item: Road"
  type     checkbox
  help     "This indicates that the item surveyed was a road.  At least one item type is required."
  pdf      if 23b. then cross L 295.80 R 303.60 B 493.08 T 500.88

field 24.
  label    "25. Building Type"
  type     restricted
  mchoice  Single a. Single Family Home
  mchoice  Townhouse b. Townhouse or Condo
  mchoice  Apartment c. Apartment
  mchoice  Mobile d. Mobile Home or Trailer
  mchoice  Business e. Business
  mchoice  Other f. Other
  presence if 23a. then required else blocked
  help     "This indicates the type of building surveyed, if applicable."
  pdf      if 24.=Single then circle X 155.64 Y 479.70 R 2.84
  pdf      if 24.=Mobile then circle X 335.64 Y 479.70 R 2.84
  pdf      if 24.=Townhouse then circle X 155.64 Y 464.28 R 2.72
  pdf      if 24.=Business then circle X 335.64 Y 464.22 R 2.84
  pdf      if 24.=Apartment then circle X 155.64 Y 448.68 R 2.72
  pdf      if 24.=Other then circle X 335.64 Y 448.62 R 2.84

field 26.
  label    "26. Damage Categorization"
  type     restricted
  choice   Affected
  choice   Minor
  choice   Major
  choice   Destroyed
  presence required
  help     "This indicates the level of damage to the property surveyed.  It is required."
  pdf      if 26.=Affected then circle X 191.58 Y 432.12 R 2.78
  pdf      if 26.=Major then circle X 371.64 Y 432.06 R 2.84
  pdf      if 26.=Minor then circle X 191.64 Y 416.58 R 2.84
  pdf      if 26.=Destroyed then circle X 371.70 Y 416.64 R 2.90

field 27. defaultBody
  label    "27. Other Damage Observed"
  type     multiline
  width    108
  help     "This describes any other damage observed during the survey."
  pdf      text L  41.44 R 563.44 B 302.12 T 393.16 A lT

field OpRelayRcvd
  label    "Operator: Relay Received"
  width    36
  help     "This is the name of the station from which this message was directly received.  It is filled in for messages that go through a relay station."
  pdf      text L 108.88 R 319.48 B 258.32 T 272.80 BL 261.84

field OpRelaySent
  label    "Operator: Relay Sent"
  width    36
  help     "This is the name of the station to which this message was directly sent.  It is filled in for messages that go through a relay station."
  pdf      text L 353.92 R 564.76 B 258.32 T 272.80 BL 261.84

field OpName operatorName
  label    "Operator: Name"
  presence required
  pdf      text L  74.92 R 247.72 B 239.48 T 253.84 BL 243.00

field OpCall operatorCall
  label    "Operator: Call Sign"
  presence required
  pdf      text L 300.16 R 364.24 B 239.48 T 253.84 BL 243.00

field -
  label    Operator
  type     join
  children OpName OpCall

field OpDate operatorDate
  label    "Operator: Date"
  type     date
  pdf      text L 399.88 R 471.88 B 239.48 T 253.84 BL 243.00

field OpTime operatorTime
  label    "Operator: Time"
  type     time
  pdf      text L 535.84 R 564.76 B 239.48 T 253.84 BL 243.00

field -
  label    "Operator: Date/Time"
  type     dateTime
  children OpDate OpTime

field -
  pdf      box L 281.40 R 333.84 B  48.24 T  59.04 F FFFFFF
