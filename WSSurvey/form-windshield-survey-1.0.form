field -
  label    "Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required

field 5. handling
  label    Handling
  type     restricted
  value    ROUTINE
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  pdf      if 5.=IMMEDIATE then circle X 309.84 Y 666.48 R 2.72
