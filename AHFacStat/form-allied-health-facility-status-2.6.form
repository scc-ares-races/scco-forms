addon    SCCoPIFO
html     form-allied-health-facility-status.html
version  2.6
title    Allied Health Facility Status Form
indef    an allied health facility status form
create   AHFacStat a
pdfFile  Allied_Health_Facility_Status_DEOC-9_v20180200_with_XSC_RACES_Routing_Slip_v20190527.pdf

field MsgNo originMessageID
  label    "Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 223.72 R 357.76 B 710.12 T 726.28 BL 714.45
  pdf      text P 2 L 468.00 R 589.12 B 742.10 T 780.01 A rb

field DestMsgNo destinationMessageID
  label    "Destination Message Number"
  type     messageID
  pdf      text L 454.60 R 573.76 B 710.12 T 726.28 BL 714.45

field 1a. messageDate
  label    "Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  75.28 R 141.76 B 650.00 T 665.32 BL 653.83

field 1b. messageTime
  label    "Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 211.48 R 245.32 B 650.00 T 665.32 BL 653.83

field -
  label    "Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    Handling
  type     restricted
  value    ROUTINE
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 313.56 Y 657.90 R 2.8
  pdf      if 5.=PRIORITY then circle X 413.16 Y 657.90 R 2.8
  pdf      if 5.=ROUTINE then circle X 496.80 Y 657.90 R 2.8

field 7a. toICSPosition
  label    "To ICS Position"
  value    "Health Care Liaison"
  choice   Health Care Liaison
  choice   EMS Unit
  choice   Public Health Unit
  choice   Medical Health Branch
  choice   Operations Section
  presence required
  width    30
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 132.16 R 303.28 B 629.72 T 645.04 BL 633.59

field 7b. toLocation
  label    "To Location"
  value    PHDOC
  choice   PHDOC
  choice   County EOC
  presence required
  width    32
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 132.16 R 303.28 B 609.92 T 625.24 BL 613.77

field 7c. toName
  label    "To Name"
  width    34
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 132.16 R 303.28 B 590.12 T 605.44 BL 594.07

field 7d. toContact
  label    "To Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 132.16 R 303.76 B 570.32 T 585.64 BL 574.20

field 8a. fromICSPosition
  label    "From ICS Position"
  presence required
  width    30
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 405.40 R 571.96 B 629.72 T 645.04 BL 633.59

field 8b. fromLocation
  label    "From Location"
  presence required
  width    32
  help     "This is the location of the message author.  It is required."
  pdf      text L 405.40 R 571.96 B 609.92 T 625.24 BL 613.77

field 8c. fromName
  label    "From Name"
  width    34
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 405.40 R 571.96 B 590.12 T 605.44 BL 594.07

field 8d. fromContact
  label    "From Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 405.40 R 572.44 B 570.32 T 585.64 BL 574.20

field -
  type     static
  value    "Allied Health Facility Status"
  pdf      text L 118.36 R 303.76 B 550.88 T 565.36 BL 554.41

field 19.
  label    "Report Type"
  type     restricted
  choice   Update
  choice   Complete
  presence required
  help     "This indicates whether the form should \"Update\" the previous status report for the facility, or whether it is a \"Complete\" replacement of the previous report.  This field is required."

field 20. messageSummary
  label    "Facility Name"
  presence required
  width    52
  help     "This is the name of the facility whose status is being reported.  It is required."
  pdf      text L 350.44 R 572.44 B 550.88 T 565.36 BL 554.41
  pdf      text P 2 L  20.96 R 334.00 B 651.68 T 672.04

field 21.
  label    "Facility Type"
  presence if 20.=Complete then required
  width    21
  help     "This is the type of the facility, such as Skilled Nursing, Home Health, Dialysis, Community Health Center, Surgical Center, or Hospice.  It is required when the \"Report Type\" is \"Complete\"."
  pdf      text P 2 L 339.08 R 467.22 B 651.68 T 672.04

field 22d. formDate
  label    Date
  type     date
  presence required
  help     "This is the date of the status report, in MM/DD/YYYY format.  It is required."
  pdf      text P 2 L 468.00 R 538.89 B 651.68 T 672.04

field 22t.
  label    Time
  type     time
  presence required
  help     "This is the time of the status report, in HH:MM format (24-hour clock).  It is required."
  pdf      text P 2 L 539.89 R 589.12 B 651.68 T 672.04

field -
  label    Date/Time
  type     dateTime
  children 22d. 22t.
  presence required
  help     "This is the date and time of the status report, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 23.
  label    "Contact Name"
  presence if 20.=Complete then required
  width    52
  help     "This is the name of the person to be contacted with questions about this report.  It is required when the \"Report Type\" is \"Complete\"."
  pdf      text P 2 L  20.96 R 334.00 B 618.44 T 638.80

field 23p.
  label    "Contact Phone"
  type     phoneNumber
  presence if 20.=Complete then required
  width    19
  help     "This is the phone number of the person to be contacted with questions about this report.  It is required when the \"Report Type\" is \"Complete\"."
  pdf      text P 2 L 339.08 R 450.88 B 618.44 T 638.80

field 23f.
  label    "Contact Fax"
  type     phoneNumber
  width    22
  help     "This is the fax number of the person to be contacted with questions about this report."
  pdf      text P 2 L 455.96 R 589.12 B 618.44 T 638.80

field 24.
  label    "Other Contact"
  width    53
  help     "This is additional contact information for the person to be contacted with questions about this report."
  pdf      text P 2 L  20.96 R 333.28 B 585.08 T 605.56

field 25.
  label    "Incident Name"
  presence if 20.=Complete then required
  width    42
  help     "This is the assigned incident name of the incident for which this report is filed.  It is required when the \"Report Type\" is \"Complete\"."
  pdf      text P 2 L 339.08 R 588.40 B 595.08 T 605.56

field 25d.
  label    "Incident Date"
  type     date
  presence if 20.=Complete then required
  help     "This is the date of the incident for which this report is filed, in MM/DD/YYYY format.  It is required when the \"Report Type\" is \"Complete\"."
  pdf      text P 2 L 339.08 R 588.40 B 585.08 T 595.08 A rF

field 35.
  label    "Facility Status"
  type     restricted
  choice   Fully Functional
  choice   Limited Services
  choice   Impaired/Closed
  presence if 20.=Complete then required
  help     "This indicates the status of the facility.  It is required when the \"Report Type\" is \"Complete\"."
  pdf      if 35.="Fully Functional" then cross P 2 L 307.82 R 318.34 B 553.04 T 563.56
  pdf      if 35.="Limited Services" then cross P 2 L 307.82 R 318.34 B 537.92 T 548.44
  pdf      if 35.=Impaired/Closed then cross P 2 L 307.82 R 318.34 B 520.58 T 531.10

field 27p.
  label    "EOC Main Contact Number"
  type     phoneNumber
  presence if 20.=Complete then required
  width    19
  help     "This is the main phone number for the facility's Emergency Operations Center (EOC).  It is required when the \"Report Type\" is \"Complete\"."
