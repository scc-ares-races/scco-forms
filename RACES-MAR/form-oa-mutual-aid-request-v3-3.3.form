addon    SCCoPIFO
html     form-oa-mutual-aid-request-v3.html
version  3.3
title    RACES Mutual Aid Request Form
indef    a RACES mutual aid request form
create   RACES-MAR rm
pdfFile  XSC_RACES_MA_Req_v20260307.pdf
deftext  FT Times-Roman FS 12.0 MS 8.0 LH 1.15 A lF WR f CL t C 000099

field MsgNo originMessageID
  label    "1. Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 227.32 R 330.76 B 725.96 T 740.68 BL 729.60
  pdf      if RECEIVED then text P 2 L 437.12 R 576.12 B 721.44 T 761.40 BL 745.56

field DestMsgNo destinationMessageID
  label    "2. Destination Message Number"
  type     messageID
  pdf      text L 438.52 R 575.08 B 725.96 T 740.68 BL 729.60

field 1a. messageDate
  label    "3. Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  83.56 R 136.60 B 689.84 T 704.56 BL 693.48

field 1b. messageTime
  label    "4. Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 184.36 R 245.32 B 689.84 T 704.56 BL 693.48

field -
  label    "3-4. Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    "5. Handling"
  type     restricted
  value    ROUTINE
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 318.90 Y 697.56 R 2.90
  pdf      if 5.=PRIORITY then circle X 415.80 Y 697.50 R 2.84
  pdf      if 5.=ROUTINE then circle X 496.92 Y 697.50 R 2.84

field 7a. toICSPosition
  label    "6. To ICS Position"
  value    "RACES Chief Radio Officer"
  choice   RACES Chief Radio Officer
  choice   RACES Unit
  choice   Planning
  presence required
  width    30
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 136.72 R 293.20 B 670.64 T 685.36 BL 674.28

field 7b. toLocation
  label    "7. To Location"
  value    "County EOC"
  presence required
  width    32
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 136.72 R 293.20 B 651.44 T 666.16 BL 655.08

field 7c. toName
  label    "8. To Name"
  width    34
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 136.72 R 293.20 B 632.24 T 646.96 BL 635.88

field 7d. toContact
  label    "9. To Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 136.72 R 293.20 B 613.04 T 627.76 BL 616.68

field 8a. fromICSPosition
  label    "10. From ICS Position"
  presence required
  width    30
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 402.52 R 575.08 B 670.64 T 685.36 BL 674.28

field 8b. fromLocation
  label    "11. From Location"
  presence required
  width    32
  help     "This is the location of the message author.  It is required."
  pdf      text L 402.52 R 575.08 B 651.44 T 666.16 BL 655.08

field 8c. fromName
  label    "12. From Name"
  width    34
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 402.52 R 575.08 B 632.24 T 646.96 BL 635.88

field 8d. fromContact
  label    "13. From Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 402.52 R 575.08 B 613.04 T 627.76 BL 616.68

field 15. messageSummary
  label    "20a. Agency Name"
  presence required
  width    80
  help     "This is the name of the agency requesting mutual aid.  It is required."
  pdf      text L 184.12 R 317.32 B 593.84 T 608.56 BL 600.96
  pdf      if RECEIVED then text P 2 L 170.32 R 376.72 B 677.84 T 698.20 BL 690.60

field 15b.
  label    "20b. Original Message Number"
  width    80
  help     "If this is a reauthorization, put the message number of the original authorization here."
  pdf      text L 475.24 R 575.08 B 593.84 T 608.56 BL 600.96
  pdf      if RECEIVED then text P 2 L 383.20 R 575.44 B 677.84 T 686.92 A lt

field 16a.
  label    "21a. Event Name"
  presence required
  width    52
  help     "This is the name of the event for which mutual aid is being requested.  It is required."
  pdf      text L 184.00 R 317.32 B 574.64 T 589.36 BL 581.76

field 16b.
  label    "21b. Event Number"
  width    17
  help     "This is the requesting agency's activation number for the event for which mutual aid is being requested."
  pdf      text L 393.88 R 575.08 B 574.64 T 589.36 BL 581.76

field -
  label    "21. Event Name/Number"
  type     join
  children 16a. 16b.

field 17. defaultBody
  label    "22. Assignment"
  type     multiline
  presence required
  width    94
  help     "This is a description of the assignment.  Describe the type of duties, conditions, any special equipment needed (other than 12-hour Go Kit). If multiple shifts are involved, give details. Provide enough detail for volunteer to decide if they are willing and able to accept the assignment.  This field is required."
  pdf      text L 143.08 R 575.08 B 479.72 T 570.16 A lt
  pdf      if RECEIVED then text P 2 L 107.80 R 573.52 B 481.76 T 565.00 A lt

field 18.1a.
  label    "23a. Resource 1 Quantity"
  type     cardinalNumber
  presence required
  width    2
  help     "This is the number of people needed for the role and position requested on this row."
  pdf      text L 150.40 R 173.32 B 446.60 T 461.32 BL 453.72
  pdf      if RECEIVED then text P 2 L 139.12 R 164.32 B 351.44 T 363.16

field 18.1b.
  label    "23b. Resource 1 Role"
  type     restricted
  choice   Field Communicator
  choice   Net Control Operator
  choice   Packet Operator
  choice   Shadow Communicator
  presence required
  help     "This is the role of the people requested on this row.  It is required when there is a quantity on the row."
  pdf      text L 187.48 R 290.32 B 446.60 T 461.32 BL 453.72
  pdf      if RECEIVED then text P 2 L 170.80 R 281.32 B 351.44 T 363.16

field 18.1f.
  label    "23c. Resource 1 Position"
  width    31
  help     "This is the position to be held by the people requested on this row."
  pdf      text L 303.40 R 432.28 B 446.60 T 461.32 BL 453.72
  pdf      if RECEIVED then text P 2 L 287.80 R 403.24 B 351.44 T 363.16

field 18.1g.
  label    "Resource 1 Together"
  type     checkbox
  help     "If this box is checked, this position should be filled only if the other positions with this box checked can also be filled."
  pdf      if 18.1g. then cross L 435.12 R 442.80 B 449.28 T 457.80
  pdf      if RECEIVED then if 18.1g. then cross P 2 L 406.08 R 413.76 B 353.28 T 361.68

