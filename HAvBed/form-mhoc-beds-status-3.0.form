addon    SCCoPIFO
html     form-mhoc-beds-status-v3.html
version  3.0
title    Hospital Bed Availability Report
indef    a hospital bed availability report
create   HAvBed hb
pdfFile  XSC_HAvBed_Report_v20260223.pdf
deftext  FT Times-Roman FS 12.0 MS 8.0 LH 1.15 A lF WR f CL t C 000099

field MsgNo originMessageID
  label    "1. Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 228.64 R 339.76 B 716.24 T 730.96 BL 719.76

field DestMsgNo destinationMessageID
  label    "2. Destination Message Number"
  type     messageID
  pdf      text L 447.16 R 546.88 B 716.24 T 730.96 BL 719.76

field 1a. messageDate
  label    "3. Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  80.32 R 128.32 B 657.20 T 676.48 BL 663.12

field 1b. messageTime
  label    "4. Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 173.44 R 218.32 B 657.20 T 676.48 BL 663.12

field -
  label    "Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    "5. Handling"
  type     restricted
  value    IMMEDIATE
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 294.24 Y 667.08 R 2.72
  pdf      if 5.=PRIORITY then circle X 390.78 Y 667.14 R 2.78
  pdf      if 5.=ROUTINE then circle X 471.66 Y 667.08 R 2.78

field 7a. toICSPosition
  label    "6. To ICS Position"
  value    "EMS Unit"
  choice   EMS Unit
  choice   Medical Health Branch
  choice   Operations Section
  presence required
  width    30
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 138.16 R 285.76 B 635.12 T 652.72 BL 640.08

field 7b. toLocation
  label    "7. To Location"
  value    PHDOC
  choice   PHDOC
  choice   County EOC
  presence required
  width    32
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 138.16 R 285.76 B 612.80 T 630.64 BL 618.00

field 7c. toName
  label    "8. To Name"
  width    34
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 138.16 R 285.76 B 590.24 T 608.32 BL 595.44

field 7d. toContact
  label    "9. To Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 138.16 R 285.76 B 567.68 T 585.76 BL 572.88

field 8a. fromICSPosition
  label    "10. From ICS Position"
  presence required
  width    30
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 394.72 R 550.00 B 635.12 T 652.72 BL 640.08

field 8b. fromLocation
  label    "11. From Location"
  presence required
  width    32
  help     "This is the location of the message author.  It is required."
  pdf      text L 394.72 R 550.00 B 612.80 T 630.64 BL 618.00

field 8c. fromName
  label    "12. From Name"
  width    34
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 394.72 R 550.00 B 590.24 T 608.32 BL 595.44

field 8d. fromContact
  label    "13. From Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 394.72 R 550.00 B 567.68 T 585.76 BL 572.88

field 20. messageSummary
  label    "21. Hospital Name"
  type     restricted
  choice   El Camino Hospital Los Gatos
  choice   El Camino Hospital Mountain View
  choice   Good Samaritan Hospital
  choice   Kaiser San Jose Medical Center
  choice   Kaiser Santa Clara Hospital
  choice   Lucile Packard Children's Hospital
  choice   O'Connor Hospital
  choice   Palo Alto Veterans Hospital
  choice   Regional San Jose Medical Center
  choice   Saint Louise Regional Hospital
  choice   Stanford Hospital
  choice   Stanford School of Medicine
  choice   Valley Medical Center
  presence required
  help     "This is the name of the hospital reporting availability.  It is required."
  pdf      text L 171.76 R 550.00 B 527.12 T 545.20 BL 532.32

field 41.
  label    "31. Adult ICU"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available adult beds that can support critical patients, including ventilator support.  It is required."
  pdf      text L 191.76 R 252.32 B 476.24 T 492.40 BL 480.48 A rF

field 52.
  label    "32. Adult Telemetry Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available adult beds equipped with telemetry monitoring.  It is required."
  pdf      text L 191.76 R 252.32 B 455.60 T 471.76 BL 459.84 A rF

field 43.
  label    "33. Adult Medical/Surgical Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available adult medical/surgical beds, also known as ward beds.  It is required."
  pdf      text L 191.76 R 252.32 B 434.96 T 451.12 BL 439.20 A rF

field 46.
  label    "34. Pediatric ICU Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available pediatric beds that can support critical patients, including ventilator support.  It is required."
  pdf      text L 191.76 R 252.32 B 414.32 T 430.48 BL 418.56 A rF

field 53.
  label    "35. Neonatal ICU Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available neonatal intensive care unit beds.  It is required."
  pdf      text L 191.76 R 252.32 B 393.68 T 409.84 BL 397.92 A rF

field 54.
  label    "36. Pediatric Telemetry Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available pediatric beds equipped with telemetry monitoring.  It is required."
  pdf      text L 191.76 R 252.32 B 373.04 T 389.20 BL 377.28 A rF

field 47.
  label    "37. Pediatric Medical/Surgical Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available pediatric medical/surgical beds, also known as ward beds.  It is required."
  pdf      text L 191.76 R 252.32 B 352.40 T 368.56 BL 356.64 A rF

field 42.
  label    "38. Burn ICU Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available burn ICU beds.  It is required.  These beds are not to be included in other ICU bed counts."
  pdf      text L 191.76 R 252.32 B 331.76 T 347.92 BL 336.00 A rF

field 55.
  label    "39. OB/GYN Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available beds used during labor, delivery, and postpartum care.  It is required."
  pdf      text L 191.76 R 252.32 B 311.12 T 327.28 BL 315.36 A rF

field 48.
  label    "40. Psychiatric"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available psychiatric unit beds (ward beds on a closed/locked unit with a sitter).  It is required."
  pdf      text L 191.76 R 252.32 B 290.48 T 306.64 BL 294.72 A rF

field 56.
  label    "41. TOTAL"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the total number of available beds In the above categories.  It is required."
  pdf      text L 191.76 R 252.32 B 269.84 T 286.00 BL 274.08 A rF

field 45.
  label    "42. Operating Room Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available operating room beds.  It is required."
  pdf      text L 191.76 R 252.32 B 249.20 T 265.36 BL 253.44 A rF

field 44.
  label    "43. Isolation Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available isolation unit beds.  It is required."
  pdf      text L 191.76 R 252.32 B 228.56 T 244.72 BL 232.80 A rF

field 50.
  label    "44. Ventilator Beds"
  type     cardinalNumber
  presence required
  width    11
  help     "This is the number of available ventilator-equipped beds.  It is required."
  pdf      text L 191.76 R 252.32 B 207.92 T 224.08 BL 212.16 A rF

field 51.
  label    "45. Comment"
  type     multiline
  help     "This field contains comments about the report."
  pdf      text L 109.00 R 550.00 B 145.76 T 203.44 BL 194.88

field OpRelayRcvd
  label    "Operator: Relay Received"
  width    36
  help     "This is the name of the station from which this message was directly received.  It is filled in for messages that go through a relay station."
  pdf      text L 110.08 R 308.32 B  86.48 T 100.96 BL  95.28

field OpRelaySent
  label    "Operator: Relay Sent"
  width    36
  help     "This is the name of the station to which this message was directly sent.  It is filled in for messages that go through a relay station."
  pdf      text L 342.64 R 551.20 B  86.48 T 100.96 BL  95.28

field OpName operatorName
  label    "Operator: Name"
  presence required
  pdf      text L  74.80 R 227.20 B  73.04 T  87.52 BL 76.32

field OpCall operatorCall
  label    "Operator: Call Sign"
  presence required
  pdf      text L 279.40 R 344.32 B  73.04 T  87.52 BL 76.32

field -
  label    Operator
  type     join
  children OpName OpCall

field OpDate operatorDate
  label    "Operator: Date"
  type     date
  pdf      text L 377.84 R 443.20 B  73.04 T  87.52 BL 76.32

field OpTime operatorTime
  label    "Operator: Time"
  type     time
  pdf      text L 507.28 R 551.20 B  73.04 T  87.52 BL 76.32

field -
  label    "Operator: Date/Time"
  type     dateTime
  children OpDate OpTime

field -
  pdf      box L  32.28 R 120.24 B  36.12 T  49.92 F FFFFFF
  pdf      box L 521.64 R 579.96 B  36.12 T  49.92 F FFFFFF
