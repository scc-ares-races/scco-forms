addon    SCCoPIFO
html     form-notable-report.html
version  1.1
title    Notable Report Form
indef    a notable report form
create   NotRep n
pdfFile  Notable_Report_v20260307.pdf
deftext  FT Times-Roman FS 12.0 MS 8.0 LH 1.15 A lF WR f CL t C 000099

field MsgNo originMessageID
  label    "1. Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 233.20 R 335.20 B 726.56 T 744.40 BL 731.76

field DestMsgNo destinationMessageID
  label    "2. Destination Message Number"
  type     messageID
  pdf      text L 445.72 R 564.88 B 726.56 T 744.40 BL 731.76

field 1a. messageDate
  label    "3. Message Date"
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  81.04 R 132.88 B 672.32 T 692.32 BL 678.48

field 1b. messageTime
  label    "4. Message Time"
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 181.12 R 236.32 B 672.32 T 692.32 BL 678.48

field -
  label    "Message Date/Time"
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    "5. Handling"
  type     restricted
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 309.72 Y 682.74 R 2.72
  pdf      if 5.=PRIORITY then circle X 406.86 Y 682.74 R 2.66
  pdf      if 5.=ROUTINE then circle X 487.92 Y 682.68 R 2.84

field 7a. toICSPosition
  label    "6. To ICS Position"
  value    "Situational Analysis Unit"
  choice   Situational Analysis Unit
  choice   Common Operating Picture Spec.
  choice   Planning
  presence required
  width    30
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L 148.12 R 299.20 B 654.32 T 667.36 BL 656.64

field 7b. toLocation
  label    "7. To Location"
  value    "County EOC"
  presence required
  width    32
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L 148.12 R 299.20 B 636.32 T 649.36 BL 638.64

field 7c. toName
  label    "8. To Name"
  width    34
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L 148.12 R 299.20 B 618.32 T 631.36 BL 620.64

field 7d. toContact
  label    "9. To Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the receipient.  It is optional and rarely provided."
  pdf      text L 148.12 R 299.20 B 596.24 T 613.36 BL 600.72

field 8a. fromICSPosition
  label    "10. From ICS Position"
  presence required
  width    30
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 410.68 R 563.68 B 654.32 T 667.36 BL 656.64

field 8b. fromLocation
  label    "11. From Location"
  presence required
  width    32
  help     "This is the location of the message author.  It is required."
  pdf      text L 410.68 R 563.68 B 636.32 T 649.36 BL 638.64

field 8c. fromName
  label    "12. From Name"
  width    34
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 410.68 R 563.68 B 618.32 T 631.36 BL 620.64

field 8d. fromContact
  label    "13. From Contact Info"
  width    29
  help     "This is contact information (phone number, email, etc.) for the message author.  It is optional and rarely provided."
  pdf      text L 410.68 R 563.68 B 596.24 T 613.36 BL 600.72

field 20.
  label    "21. Jurisdiction"
  choice   Campbell
  choice   Cupertino
  choice   Gilroy
  choice   Los Altos
  choice   Los Altos Hills
  choice   Los Gatos
  choice   Milpitas
  choice   Monte Sereno
  choice   Morgan Hill
  choice   Mountain View
  choice   Palo Alto
  choice   San Jose
  choice   Santa Clara (City)
  choice   Saratoga
  choice   Sunnyvale
  choice   Santa Clara County
  choice   County unincorporated
  presence required
  help     "This is the name of the jurisdiction originating the notable report.  It is required."
  pdf      text L 116.20 R 299.20 B 559.76 T 573.28 BL 562.56

field 21.
  label    "22. Originator"
  presence required
  width    999
  help     "This is the originator of the notable report.  It is required."
  pdf      text L 376.84 R 563.68 B 559.76 T 573.28 BL 562.56

field 22.
  label    "23. Severity"
  type     restricted
  choice   High
  choice   Medium
  choice   Low
  presence required
  help     "This is the severity of the notable report.  It is required."
  pdf      if 22.=High then circle X 227.46 Y 548.28 R 2.78
  pdf      if 22.=Medium then circle X 299.46 Y 548.28 R 2.78
  pdf      if 22.=Low then circle X 407.46 Y 548.28 R 2.78

field 23.
  label    "24. Escalate to County Op Area?"
  type     restricted
  choice   Yes
  choice   No
  presence required
  help     "This indicates whether the notable report should be escalated to the county operational area.  It is required."
  pdf      if 23.=Yes then circle X 227.46 Y 530.28 R 2.78
  pdf      if 23.=No then circle X 299.46 Y 530.28 R 2.78

field 24.
  type     static
  value    if 25. then Yes else if 23.=Yes then No

field 25.
  label    "25. Name of the County Incident"
  presence if 23.=Yes then optional else blocked
  width    59
  help     "This is the county operational area's name for the incident leading to this notable report, if any.  It is only allowed when \"Escalate to County Op Area?\" is \"Yes\"."
  pdf      text L 195.64 R 563.68 B 505.28 T 518.80 BL 508.08

field 30. messageSummary
  label    "31. Title"
  presence required
  width    102
  help     "This is the title of the notable report.  It should be unique among all notable reports from the same jurisdiction.  It is required."
  pdf      text L  86.56 R 563.68 B 469.28 T 482.80 BL 472.08

field 31d. formDate
  label    "32. Date"
  type     date
  presence required
  help     "This is the date of the event being reported.  It is required."
  pdf      text L  86.56 R 299.92 B 451.28 T 464.80 BL 454.08

field 31t.
  label    "33. Time"
  type     time
  presence required
  help     "This is the time of day of the event being reported.  It is required."
  pdf      text L 352.96 R 563.68 B 451.28 T 464.80 BL 454.08

field -
  label    Date/Time
  type     dateTime
  children 31d. 31t.
  presence required
  help     "This is the date and time of the event being reported, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 32.
  label    "34. Event Type"
  type     restricted
  mchoice  1 1: Transportation
  mchoice  2 2: Communications
  mchoice  3 3: Construction and Engineering
  mchoice  4 4: Fire and Rescue
  mchoice  5 5: Management
  mchoice  6 6: Care and Shelter
  mchoice  7 7: Resources
  mchoice  8 8: Public Health and Medical
  mchoice  9 9: Search and Rescue
  mchoice  10 10: Hazardous Materials Response
  mchoice  11 11: Food and Agriculture
  mchoice  12 12: Utilities
  mchoice  13 13: Law Enforcement
  mchoice  14 14: Recovery
  mchoice  15 15: Public Information
  mchoice  16 16: Animal Services
  mchoice  17 17: Volunteer Management
  mchoice  18 18: Cybersecurity
  mchoice  19 19: Donations Management
  mchoice  20 20: Continuity of Operations/Government
  presence required
  help     "This is the type of event being reported.  It is required."
  pdf      if 32.=1 then circle X  58.74 Y 427.86 R 2.78
  pdf      if 32.=8 then circle X 227.46 Y 427.80 R 2.66
  pdf      if 32.=15 then circle X 407.46 Y 427.80 R 2.66
  pdf      if 32.=2 then circle X  58.74 Y 412.26 R 2.78
  pdf      if 32.=9 then circle X 227.46 Y 412.20 R 2.66
  pdf      if 32.=16 then circle X 407.46 Y 412.20 R 2.66
  pdf      if 32.=3 then circle X  58.74 Y 396.66 R 2.78
  pdf      if 32.=10 then circle X 407.52 Y 396.66 R 2.72
  pdf      if 32.=17 then circle X 227.46 Y 396.60 R 2.78
  pdf      if 32.=4 then circle X  58.74 Y 381.30 R 2.78
  pdf      if 32.=11 then circle X 227.46 Y 381.24 R 2.78
  pdf      if 32.=18 then circle X 407.52 Y 381.24 R 2.84
  pdf      if 32.=5 then circle X  58.74 Y 365.70 R 2.54
  pdf      if 32.=12 then circle X 227.46 Y 365.64 R 2.66
  pdf      if 32.=19 then circle X 407.46 Y 365.70 R 2.54
  pdf      if 32.=6 then circle X  58.74 Y 350.10 R 2.78
  pdf      if 32.=13 then circle X 227.52 Y 350.04 R 2.84
  pdf      if 32.=20 then circle X 407.52 Y 350.04 R 2.84
  pdf      if 32.=7 then circle X  58.74 Y 334.50 R 2.78
  pdf      if 32.=14 then circle X 227.52 Y 334.44 R 2.84

field 33. defaultBody
  label    "35. Details"
  type     multiline
  presence required
  width    108
  help     "This gives the details of the report.  It is required."
  pdf      text L  96.40 R 563.68 B 274.16 T 310.48 BL 301.92

field 40.
  label    "41. Point of Contact Name"
  width    30
  help     "This gives the name of the contact person for the report.  It is required."
  pdf      text L 167.56 R 299.20 B 236.96 T 250.00 BL 239.52

field 41.
  label    "42. Contact Phone Number"
  type     phoneNumber
  width    29
  help     "This gives the phone number of the contact person for the report."
  pdf      text L 436.60 R 563.68 B 236.96 T 250.00 BL 239.52

field 42.
  label    "43. Contact Email"
  width    85
  help     "This gives the email address of the contact person for the report."
  pdf      text L 167.56 R 563.68 B 218.96 T 232.48 BL 221.76

field 50.
  label    "51. Event Expires?"
  type     restricted
  choice   Yes
  choice   No
  presence required
  help     "This indicates whether the event being reported will expire.  It is required."
  pdf      if 50.=Yes then circle X 231.48 Y 191.16 R 2.84
  pdf      if 50.=No then circle X 267.72 Y 191.16 R 2.84

field 51.
  label    "52. Date to Expire"
  type     date
  presence if 50.=Yes then required else blocked
  help     "This is the date when the event being reported will expire.  It is only allowed when \"Event Expires\" is \"Yes\"."
  pdf      text L 394.72 R 563.68 B 185.12 T 196.72 BL 187.20

field OpRelayRcvd
  label    "Operator: Relay Received"
  width    36
  help     "This is the name of the station from which this message was directly received.  It is filled in for messages that go through a relay station."
  pdf      text L 108.88 R 320.56 B 141.44 T 155.92 BL 144.96

field OpRelaySent
  label    "Operator: Relay Sent"
  width    36
  help     "This is the name of the station to which this message was directly sent.  It is filled in for messages that go through a relay station."
  pdf      text L 354.88 R 564.88 B 141.44 T 155.92 BL 144.96

field OpName operatorName
  label    "Operator: Name"
  presence required
  pdf      text L  74.80 R 204.88 B 122.48 T 136.96 BL 126.00

field OpCall operatorCall
  label    "Operator: Call Sign"
  presence required
  pdf      text L 256.84 R 326.32 B 122.48 T 136.96 BL 126.00

field -
  label    Operator
  type     join
  children OpName OpCall

field OpDate operatorDate
  label    "Operator: Date"
  type     date
  pdf      text L 361.84 R 420.88 B 122.48 T 136.96 BL 126.00

field OpTime operatorTime
  label    "Operator: Time"
  type     time
  pdf      text L 484.72 R 564.88 B 122.48 T 136.96 BL 126.00

field -
  label    "Operator: Date/Time"
  type     dateTime
  children OpDate OpTime

field -
  pdf      box L 280.44 R 332.40 B  22.68 T  34.08 F FFFFFF
