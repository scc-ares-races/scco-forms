addon    SCCoPIFO
html     form-ics213.html
version  2.3
title    ICS-213 General Message Form
indef    an ICS-213 general message form
create   ICS213 i
pdfFile  ICS-213_SCC_Message_Form_v220119_fillable.pdf
deftext  FT Times-Roman FS 12.0 MS 8.0 LH 1.15 A lF WR f CL t C 000099

field MsgNo originMessageID
  label    "Origin Message Number"
  type     messageID
  presence required
  help     "This is the message number assigned to the message by the origin station.  Valid message numbers have the form XXX-###P, where XXX is the three-character message number prefix assigned to the station, ### is a sequence number (any number of digits), and P is an optional suffix letter.  This field is required."
  pdf      text L 324.40 R 387.16 B 740.60 T 754.72 BL 743.88

field 3. destinationMessageID
  label    "Destination Message Number"
  type     messageID
  pdf      text L 521.08 R 580.84 B 741.32 T 754.00 BL 743.88

field 1a. messageDate
  label    Date
  type     date
  presence required
  help     "This is the date the message was written, in MM/DD/YYYY format.  It is required."
  pdf      text L  50.20 R 104.68 B 659.36 T 674.80 BL 663.85

field 1b. messageTime
  label    Time
  type     time
  presence required
  help     "This is the time the message was written, in HH:MM format (24-hour clock).  It is required."
  pdf      text L 144.76 R 185.80 B 660.44 T 676.00 BL 663.85

field -
  label    Date/Time
  type     dateTime
  children 1a. 1b.
  presence required
  help     "This is the date and time the message was written, in MM/DD/YYYY HH:MM format (24-hour clock).  It is required."

field 5. handling
  label    Handling
  type     restricted
  choice   IMMEDIATE
  choice   PRIORITY
  choice   ROUTINE
  presence required
  help     "This is the message handling order, which specifies how fast it needs to be delivered.  Allowed values are \"ROUTINE\" (within 2 hours), \"PRIORITY\" (within 1 hour), and \"IMMEDIATE\".  This field is required."
  pdf      if 5.=IMMEDIATE then circle X 306.48 Y 708.00 R 3.40
  pdf      if 5.=PRIORITY then circle X 411.78 Y 708.72 R 3.40
  pdf      if 5.=ROUTINE then circle X 509.34 Y 708.78 R 3.40

field 6a.
  label    "Take Action"
  type     restricted
  choice   Yes
  choice   No
  help     "This indicates whether the sender expects the recipient to take action based on this message."
  pdf      if 6a.=Yes then circle X 420.96 Y 668.22 R 3.00
  pdf      if 6a.=No then circle X 522.48 Y 668.16 R 3.00

field 6b.
  label    Reply
  type     restricted
  choice   Yes
  choice   No
  help     "This indicates whether the sender expects the recipient to reply to this message."
  pdf      if 6b.=Yes then circle X 420.96 Y 647.76 R 3.00
  pdf      if 6b.=No then circle X 522.48 Y 647.76 R 3.00

field 6d.
  label    "Reply By"
  presence if 6b.=Yes then optional else blocked
  width    5
  help     "This is the time by which the sender expects a reply from the recipient.  It can be set only if \"Reply\" is \"Yes\"."
  compare  exact
  pdf      text L 464.92 R 504.16 B 643.04 T 652.48 BL 644.76

field 7. toICSPosition
  label    "To ICS Position"
  presence required
  width    40
  help     "This is the ICS position to which the message is addressed.  It is required."
  pdf      text L  63.28 R 283.36 B 607.16 T 622.72 BL 611.17

field 9a. toLocation
  label    "To Location"
  presence required
  width    40
  help     "This is the location of the recipient ICS position.  It is required."
  pdf      text L  63.28 R 283.96 B 571.52 T 587.44 BL 575.71

field ToName toName
  label    "To Name"
  width    40
  help     "This is the name of the person holding the recipient ICS position.  It is optional and rarely provided."
  pdf      text L  63.28 R 283.36 B 536.60 T 551.32 BL 540.43

field ToTel toContact
  label    "To Telephone"
  width    40
  help     "This is the telephone number for the receipient.  It is optional and rarely provided."
  compare  exact
  pdf      text L  63.28 R 283.96 B 499.88 T 515.68 BL 504.01

field 8. fromICSPosition
  label    "From ICS Position"
  presence required
  width    40
  help     "This is the ICS position of the message author.  It is required."
  pdf      text L 341.08 R 566.20 B 607.16 T 622.72 BL 611.17

field 9b. fromLocation
  label    "From Location"
  presence required
  width    40
  help     "This is the location of the message author.  It is required."
  pdf      text L 341.08 R 565.60 B 571.04 T 587.44 BL 575.71

field FmName fromName
  label    "From Name"
  width    40
  help     "This is the name of the message author.  It is optional and rarely provided."
  pdf      text L 341.08 R 565.60 B 537.08 T 551.32 BL 540.43

field FmTel fromContact
  label    "From Telephone"
  width    40
  help     "This is the telephone number for the message author.  It is optional and rarely provided."
  compare  exact
  pdf      text L 341.08 R 565.60 B 499.88 T 515.68 BL 504.01

field 10. messageSummary
  label    Subject
  presence required
  width    80
  help     "This is the subject of the message.  It is required."
  pdf      text L 117.04 R 566.92 B 475.64 T 491.44 BL 480.12

field 11. reference
  label    Reference
  width    55
  help     "This is the origin message number of the previous message to which this message is responding."
  compare  exact
  pdf      text L 260.92 R 565.12 B 450.56 T 467.08 BL 455.16

field 12. defaultBody
  label    Message
  type     multiline
  presence required
  width    80
  help     "This is the text of the message.  It is required."
  pdf      text L  38.84 R 579.64 B 305.60 T 424.76 A lt

field OpRelayRcvd
  label    "Operator: Relay Received"
  width    36
  help     "This is the name of the station from which this message was directly received.  It is filled in for messages that go through a relay station."
  pdf      text L 125.44 R 306.88 B 186.08 T 199.60 BL 187.80

field OpRelaySent
  label    "Operator: Relay Sent"
  width    36
  help     "This is the name of the station to which this message was directly sent.  It is filled in for messages that go through a relay station."
  pdf      text L 378.40 R 559.84 B 185.12 T 200.20 BL 187.80

field Rec-Sent receiverSender
  label    "Operator: Receiver/Sender"
  type     restricted
  choice   sender
  choice   receiver
  pdf      if Rec-Sent=receiver then circle X  87.12 Y 171.60 R 3.00
  pdf      if Rec-Sent=sender then circle X 177.24 Y 172.56 R 3.00

field OpName operatorName
  label    "Operator: Name"
  presence required
  pdf      text L 409.84 R 573.88 B 141.80 T 153.16 BL 145.56

field OpCall operatorCall
  label    "Operator: Call Sign"
  presence required
  pdf      text L 423.40 R 577.84 B 163.04 T 178.60 BL 168.12

field -
  label    Operator
  type     join
  children OpName OpCall

field Method operatorMethod
  label    "Operator: Tx Method"
  type     restricted
  choice   Telephone
  choice   Dispatch Center
  choice   EOC Radio
  choice   FAX
  choice   Courier
  choice   Amateur Radio
  choice   Other
  presence required
  pdf      if Method=Telephone then circle X  42.24 Y 148.98 R 3.00
  pdf      if Method="Dispatch Center" then circle X 141.24 Y 148.98 R 3.00
  pdf      if Method="EOC Radio" then circle X  42.24 Y 126.42 R 3.00
  pdf      if Method=Fax then circle X 141.24 Y 126.42 R 3.00
  pdf      if Method=Courier then circle X 217.80 Y 126.48 R 3.00
  pdf      if Method="Amateur Radio" then circle X  42.24 Y 109.26 R 3.00
  pdf      if Method=Other then circle X 141.24 Y 109.26 R 3.00

field Other operatorMethodOther
  label    "Operator: Other Method"
  presence if Method=Other then optional else blocked
  pdf      text L 189.28 R 288.16 B 100.40 T 116.32 BL 105.72

field OpDate operatorDate
  label    "Operator: Date"
  type     date
  pdf      text L 355.84 R 410.32 B 100.16 T 116.32 BL 105.72

field OpTime operatorTime
  label    "Operator: Time"
  type     time
  pdf      text L 499.84 R 538.60 B 100.04 T 116.32 BL 105.72

field -
  label    "Operator: Date/Time"
  type     dateTime
  children OpDate OpTime
